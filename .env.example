# Core
DATABASE_URL=postgresql://neondb_owner:change-me@ep-your-db-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require
# MSSQL alternatifi:
# DATABASE_URL=Server=18.159.75.68,1433;Database=obilet-b2b-preprod;User Id=corp_mdemirci;Password=change-me;Encrypt=True;TrustServerCertificate=True;
# URL formatini kullanirsaniz SSL icin bunlar dikkate alinir
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=false
SESSION_SECRET=change-me
PORT=3000
NODE_ENV=development
TZ=Europe/Istanbul
PARTNERS_EXTRA_API_URLS=https://api-preprod.obus.com.tr/api

# Slack
SLACK_BOT_TOKEN=xoxb-your-token
SLACK_ANALYSIS_AUTO_SAVE_TIME=23:59
SLACK_ANALYSIS_CHANNEL_TYPES=private_channel,public_channel
SLACK_ANALYSIS_MAX_CHANNELS=300
SLACK_CORP_REQUEST_TAG=@corpproduct
SLACK_CORP_REQUEST_CHANNELS=

# All Companies / ObusMerkezSubeID (optional)
INVENTORY_BRANCHES_API_URL=https://api-coreprod-cluster4.obus.com.tr/api/inventory/getbranches
INVENTORY_BRANCHES_API_AUTH=Basic MTIzNDU2MHg2NTUwR21STG5QYXJ5bnVt
# Bu login bilgileri .env yerine macOS Keychain'den okunur.
# Servis adlari:
# MustafaWebProje/INVENTORY_BRANCHES_LOGIN_USERNAME
# MustafaWebProje/INVENTORY_BRANCHES_LOGIN_PASSWORD
# MustafaWebProje/OBUS_JOB_FIXED_USERNAME
# MustafaWebProje/OBUS_JOB_FIXED_PASSWORD
# MustafaWebProje/OBUS_USER_CREATE_LOGIN_USERNAME
# MustafaWebProje/OBUS_USER_CREATE_LOGIN_PASSWORD
OBUS_LIVE_JOB_TTL_MS=1800000
OBUS_LIVE_JOB_MAX_EVENTS=10000
ALL_COMPANIES_FETCH_TIMEOUT_MS=180000
ALL_COMPANIES_CLUSTER_CONCURRENCY=6
ALL_COMPANIES_OBUS_ENRICH_CONCURRENCY=4
INVENTORY_BRANCHES_CLUSTER_CONCURRENCY=4

# Obus Kullanici Pasife Al / Yerel SQL Proxy
OBUS_USER_DEACTIVATE_SQL_HOST=3.66.204.108
OBUS_USER_DEACTIVATE_SQL_PORT=1433
OBUS_USER_DEACTIVATE_SQL_DATABASE=b2b-production
OBUS_USER_DEACTIVATE_SQL_USERNAME=change-me
OBUS_USER_DEACTIVATE_SQL_PASSWORD=change-me
OBUS_USER_DEACTIVATE_SQL_TIMEOUT_MS=45000
OBUS_USER_DEACTIVATE_SQL_ENCRYPT=false
OBUS_USER_DEACTIVATE_SQL_PROXY_HOST=127.0.0.1
OBUS_USER_DEACTIVATE_SQL_PROXY_PORT=3015
OBUS_USER_DEACTIVATE_SQL_PROXY_TOKEN=
OBUS_USER_DEACTIVATE_SQL_PROXY_ALLOWED_ORIGIN=http://localhost:3000

# Jira (optional)
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=your-api-token
JIRA_API_TIMEOUT_MS=20000
JIRA_MAX_RESULTS=50

# ChatGPT / OpenAI (optional)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4.1-mini
