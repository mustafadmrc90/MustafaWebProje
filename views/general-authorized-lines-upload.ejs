<!DOCTYPE html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bus Product</title>
    <link rel="icon" href="/public/favicon.png" />
    <link rel="stylesheet" href="/public/styles.css" />
  </head>
  <body class="dashboard layout">
    <%- include("partials/sidebar", { active }) %>

    <section class="content">
      <header class="page-header">
        <div class="page-title">
          <h1>
            <span class="page-title-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24">
                <path d="M3 12h18"></path>
                <path d="M12 3v18"></path>
                <circle cx="12" cy="12" r="9"></circle>
              </svg>
            </span>
            <span>İzinli Hatları & UETDS Fiyatlarını Güncelle</span>
          </h1>
          <p>Authorization: Basic + JSON body ile servis çağrısı yapılır.</p>
        </div>
        <div class="page-actions">
          <div class="user-pill"><%= user.displayName %></div>
        </div>
      </header>

      <section class="table-card panel-card allowed-lines-section">
        <div class="table-head">
          <h2>İstek Parametreleri</h2>
        </div>

        <form
          class="allowed-lines-form"
          method="post"
          action="/general/authorized-lines-upload"
          data-company-source-url="<%= companySourceBaseUrl %>"
        >
          <input
            type="hidden"
            name="endpointUrl"
            id="allowed-lines-endpoint-url"
            value="<%= filters.endpointUrl %>"
          />
          <input type="hidden" name="submitAction" id="allowed-lines-submit-action" value="authorized-lines" />
          <div class="allowed-lines-grid">
            <label class="allowed-lines-field allowed-lines-field-company">
              <span>Firma</span>
              <select name="company" id="allowed-lines-company" required>
                <% companies.forEach((company) => { %>
                  <option
                    value="<%= company.value %>"
                    data-cluster="<%= company.meta && company.meta.cluster ? company.meta.cluster : '' %>"
                    <%= filters.company === company.value ? "selected" : "" %>
                    <%= company.disabled ? "disabled" : "" %>
                  >
                    <%= company.label %>
                  </option>
                <% }) %>
              </select>
            </label>
            <label class="allowed-lines-field allowed-lines-field-username">
              <span>Kullanıcı Adı</span>
              <input type="text" name="username" value="<%= filters.username || '' %>" required />
            </label>
            <label class="allowed-lines-field allowed-lines-field-password">
              <span>Şifre</span>
              <input type="password" name="password" value="<%= filters.password || '' %>" required />
            </label>
          </div>
          <div class="allowed-lines-actions">
            <button
              type="submit"
              data-submit-action="uetds-prices"
              data-default-label="UETDS Fiyatları Güncelle"
              data-loading-label="Güncelleniyor..."
            >
              UETDS Fiyatları Güncelle
            </button>
            <button
              type="submit"
              data-submit-action="authorized-lines"
              data-default-label="İzinli Hatları Yükle"
              data-loading-label="Yükleniyor..."
            >
              İzinli Hatları Yükle
            </button>
          </div>
          <div class="allowed-lines-loading-message" hidden>İstek gönderiliyor, lütfen bekleyin...</div>
        </form>

        <% if (report.requested && report.error) { %>
          <div class="alert inline-alert"><%= report.error %></div>
        <% } %>
      </section>

      <section class="table-card panel-card allowed-lines-response">
        <div class="table-head">
          <h2>Yanıt</h2>
          <div class="table-actions">
            <% if (report.requested) { %>
              <span class="pill"><%= report.status ? `HTTP ${report.status}` : "HTTP -" %></span>
            <% } else { %>
              <span class="pill muted">Henüz istek atılmadı</span>
            <% } %>
          </div>
        </div>
        <div class="allowed-lines-public-result">
          <% if (report.requested && !report.error && report.userMessage) { %>
            <div class="inline-success"><%= report.userMessage %></div>
          <% } else if (report.requested && report.error) { %>
            <div class="alert inline-alert"><%= report.error %></div>
          <% } else { %>
            <div class="pill muted">Henüz sonuç yok.</div>
          <% } %>
        </div>
        <% if (report.requested && report.requestUrl) { %>
          <div class="allowed-lines-request-url">
            <div class="label">İstek URL</div>
            <pre class="allowed-lines-debug-pre"><%= report.requestUrl %></pre>
          </div>
        <% } %>
        <% if (report.requested) { %>
          <div class="allowed-lines-result-grid">
            <div class="allowed-lines-result-item">
              <div class="label">İstek Body</div>
              <pre class="allowed-lines-debug-pre"><%= report.requestBody || "{}" %></pre>
            </div>
            <div class="allowed-lines-result-item">
              <div class="label"><%= report.error ? "Hata Detayı / Yanıt" : "Yanıt" %></div>
              <pre class="allowed-lines-debug-pre"><%= report.errorDetail || report.responseBody || "-" %></pre>
            </div>
          </div>
        <% } %>
      </section>
    </section>
    <script src="/public/app.js" defer></script>
  </body>
</html>
