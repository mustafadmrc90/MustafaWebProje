<section
  class="screen-log-panel"
  data-screen-log-panel="1"
  data-screen-log-menu-key="<%= screenLogPanel.menuKey %>"
  data-screen-log-api-path="<%= screenLogPanel.apiPath %>"
>
  <button
    type="button"
    class="screen-log-toggle ghost"
    data-screen-log-toggle="1"
    aria-expanded="false"
    aria-controls="screen-log-drawer"
  >
    Loglar
  </button>
  <div class="screen-log-drawer" id="screen-log-drawer" data-screen-log-drawer="1" hidden>
    <div class="screen-log-head">
      <strong><%= screenLogPanel.title %></strong>
      <button type="button" class="ghost" data-screen-log-refresh="1">Yenile</button>
    </div>
    <div class="screen-log-state muted" data-screen-log-state="1">
      Son 20 kayıt gösteriliyor.
    </div>
    <div class="screen-log-list" data-screen-log-list="1">
      <% if (Array.isArray(screenLogPanel.items) && screenLogPanel.items.length > 0) { %>
        <% screenLogPanel.items.forEach((item) => { %>
          <article class="screen-log-item screen-log-item-<%= item.level || 'info' %>">
            <div class="screen-log-item-head">
              <span class="screen-log-item-level"><%= String(item.level || 'info').toUpperCase() %></span>
              <time datetime="<%= item.createdAt %>"><%= item.createdAt %></time>
            </div>
            <strong class="screen-log-item-message"><%= item.message %></strong>
            <div class="screen-log-item-meta">
              <span><%= item.requestMethod %></span>
              <span><%= item.requestPath %></span>
              <span><%= item.createdByName %></span>
            </div>
            <% if (item.detailText) { %>
              <pre class="screen-log-item-detail"><%= item.detailText %></pre>
            <% } %>
          </article>
        <% }) %>
      <% } else { %>
        <div class="screen-log-empty" data-screen-log-empty="1">Henüz ekran logu yok.</div>
      <% } %>
    </div>
  </div>
</section>
