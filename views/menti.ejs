<!DOCTYPE html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bus Product</title>
    <link rel="icon" href="/public/favicon.png" />
    <link rel="stylesheet" href="/public/styles.css" />
  </head>
  <body class="dashboard layout">
    <%- include("partials/sidebar", { active }) %>

    <section class="content">
      <header class="page-header">
        <div class="page-title">
          <h1>
            <span class="page-title-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24">
                <path d="M5 12a7 7 0 0 1 7-7h5a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2h-5a7 7 0 0 1-7-7z"></path>
                <path d="M9 10h6"></path>
                <path d="M9 14h4"></path>
              </svg>
            </span>
            <span>Menti</span>
          </h1>
          <p>Menti solda acik kalir, sagda ChatGPT sohbet paneli calisir.</p>
        </div>
        <div class="page-actions">
          <div class="user-pill"><%= user.displayName %></div>
        </div>
      </header>

      <section class="menti-layout">
        <section class="table-card panel-card menti-browser-card">
          <div class="menti-browser-toolbar">
            <div class="menti-browser-address" aria-label="Menti adresi">
              <span class="menti-browser-dot" aria-hidden="true"></span>
              <span><%= mentiUrl %></span>
            </div>
            <a class="button-link ghost" href="<%= mentiUrl %>" target="_blank" rel="noopener noreferrer">
              Yeni Sekmede Ac
            </a>
          </div>

          <div class="menti-frame-note inline-alert">Menti burada acik kalir.</div>

          <div class="menti-browser-frame-wrap">
            <iframe
              class="menti-browser-frame"
              src="<%= mentiUrl %>"
              title="Menti"
              referrerpolicy="strict-origin-when-cross-origin"
              loading="eager"
              allow="clipboard-read; clipboard-write"
              data-menti-frame="1"
            ></iframe>
          </div>
        </section>

        <aside class="table-card panel-card menti-chatgpt-card" data-menti-chatgpt-chat="1">
          <div class="menti-browser-toolbar">
            <div class="menti-browser-address" aria-label="ChatGPT paneli">
              <span class="menti-browser-dot" aria-hidden="true"></span>
              <span>ChatGPT - <%= chatgptModel %></span>
            </div>
            <a class="button-link ghost" href="<%= chatgptUrl %>" target="_blank" rel="noopener noreferrer">
              ChatGPT'yi Ac
            </a>
          </div>

          <div class="menti-frame-note inline-alert" data-menti-chatgpt-status="1">
            Sorunuzu yazin. Yanitlar ChatGPT uzerinden bu panelde gelir.
          </div>

          <div class="menti-chatgpt-messages" data-menti-chatgpt-messages="1">
            <div class="menti-chatgpt-empty" data-menti-chatgpt-empty="1">
              Henuz sohbet baslamadi.
            </div>
          </div>

          <form class="menti-chatgpt-form" data-menti-chatgpt-form="1">
            <label class="menti-chatgpt-input-wrap">
              <span>Mesaj</span>
              <textarea
                rows="6"
                name="prompt"
                data-menti-chatgpt-input="1"
                placeholder="Sorunuzu buraya yazin"
                required
              ></textarea>
            </label>
            <div class="menti-chatgpt-actions">
              <button type="submit" data-menti-chatgpt-send="1">Gonder</button>
              <button type="button" class="ghost" data-menti-chatgpt-clear="1">Sohbeti Temizle</button>
            </div>
          </form>
        </aside>
      </section>
    </section>
    <script src="/public/app.js" defer></script>
  </body>
</html>
