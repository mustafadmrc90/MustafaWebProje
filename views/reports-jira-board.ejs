<!DOCTYPE html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bus Product</title>
    <link rel="icon" href="/public/favicon.png" />
    <link rel="stylesheet" href="/public/styles.css" />
  </head>
  <body class="dashboard layout jira-board-page">
    <%- include("partials/sidebar", { active }) %>

    <section class="content">
      <header class="jira-board-header">
        <div class="jira-board-header-top">
          <div class="jira-board-context">
            <span class="jira-board-breadcrumb">Raporlar / Jira Board</span>
            <h1>OBUSDEV Kanban</h1>
            <p>Backlog kolonu Jira’dan canlı çekiliyor. Diğer 3 kolon için veri eşlemesi bekleniyor.</p>
          </div>
          <div class="page-actions">
            <div class="user-pill"><%= user.displayName %></div>
          </div>
        </div>

        <div class="jira-board-toolbar">
          <div class="jira-board-toolbar-item">
            <span class="label">Toplam Kart</span>
            <strong><%= summary.totalCards %></strong>
          </div>
          <div class="jira-board-toolbar-item">
            <span class="label">Kaynak</span>
            <strong><%= boardReport.source || "Jira API" %></strong>
          </div>
          <div class="jira-board-toolbar-item">
            <span class="label">Aktif Kolonlar</span>
            <strong><%= summary.activeCards %></strong>
          </div>
          <div class="jira-board-toolbar-item">
            <span class="label">Test Edildi</span>
            <strong><%= summary.completedCards %></strong>
          </div>
        </div>
      </header>

      <% if (!jiraConfig.hasConfig) { %>
        <div class="alert inline-alert">
          Jira bağlantısı için `JIRA_BASE_URL`, `JIRA_EMAIL`, `JIRA_API_TOKEN` ortam değişkenlerini tanımlayın.
        </div>
      <% } %>

      <% if (boardReport.warning) { %>
        <div class="inline-success"><%= boardReport.warning %></div>
      <% } %>

      <% if (boardReport.error) { %>
        <div class="alert inline-alert"><%= boardReport.error %></div>
      <% } %>

      <section class="jira-board-shell">
        <% if (boardReport.jql) { %>
          <div class="jira-board-query">
            <strong>Backlog JQL</strong>
            <code><%= boardReport.jql %></code>
          </div>
        <% } %>

        <div class="jira-board-scroll">
          <div class="jira-board-grid">
          <% boardColumns.forEach((column) => { %>
            <section class="jira-board-column" data-tone="<%= column.tone %>">
              <div class="jira-board-column-head">
                <div>
                  <h3><%= column.title %></h3>
                  <p><%= column.subtitle %></p>
                </div>
                <span class="jira-board-count"><%= column.cards.length %></span>
              </div>

              <% if (column.cards.length === 0) { %>
                <div class="jira-board-empty">
                  <%= column.emptyMessage || "Bu kolona gelecek kart verisini paylaştığınızda burada göstereceğim." %>
                </div>
              <% } else { %>
                <div class="jira-board-card-list">
                  <% column.cards.forEach((card) => { %>
                    <article class="jira-board-card <%= card.blocked ? 'is-blocked' : '' %>">
                      <div class="jira-board-card-status">
                        <span class="jira-board-status-dot"></span>
                        <span><%= card.status %></span>
                      </div>
                      <div class="jira-board-card-top">
                        <% if (card.issueUrl) { %>
                          <a class="jira-board-card-link" href="<%= card.issueUrl %>" target="_blank" rel="noopener noreferrer"><%= card.key %></a>
                        <% } else { %>
                          <span class="jira-board-card-link"><%= card.key %></span>
                        <% } %>
                      </div>
                      <% if (card.issueUrl) { %>
                        <h4><a class="jira-board-title-link" href="<%= card.issueUrl %>" target="_blank" rel="noopener noreferrer"><%= card.title %></a></h4>
                      <% } else { %>
                        <h4><%= card.title %></h4>
                      <% } %>
                      <p><%= card.summary %></p>
                      <div class="jira-board-card-tags">
                        <span class="jira-board-tag"><%= card.issueType %></span>
                        <span class="jira-board-tag"><%= card.priority %></span>
                      </div>
                      <div class="jira-board-card-meta">
                        <span class="jira-board-updated"><%= card.updatedAt %></span>
                        <span class="jira-board-avatar" title="<%= card.assignee %>"><%= card.assigneeInitials %></span>
                      </div>
                    </article>
                  <% }) %>
                </div>
              <% } %>
            </section>
          <% }) %>
          </div>
        </div>
      </section>
    </section>
    <script src="/public/app.js" defer></script>
  </body>
</html>
