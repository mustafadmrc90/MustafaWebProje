<!DOCTYPE html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bus Product</title>
    <link rel="icon" href="/public/favicon.png" />
    <link rel="stylesheet" href="/public/styles.css?v=20260325-jira-board-6" />
  </head>
  <body class="dashboard layout jira-board-page">
    <%- include("partials/sidebar", { active }) %>

    <section class="content">
      <header class="jira-board-header">
        <div class="jira-board-header-top">
          <div class="jira-board-context">
            <span class="jira-board-breadcrumb">Raporlar / Jira Board</span>
            <h1>OBUSDEV Task Listesi</h1>
          </div>
          <div class="page-actions">
            <div class="user-pill"><%= user.displayName %></div>
          </div>
        </div>
      </header>

      <% if (!jiraConfig.hasConfig) { %>
        <div class="alert inline-alert">
          Jira bağlantısı için `JIRA_BASE_URL`, `JIRA_EMAIL`, `JIRA_API_TOKEN` ortam değişkenlerini tanımlayın.
        </div>
      <% } %>

      <% if (boardReport.error) { %>
        <div class="alert inline-alert"><%= boardReport.error %></div>
      <% } %>

      <section class="jira-board-shell asana-list-shell">
        <% boardColumns.forEach((column) => { %>
          <section class="asana-group" data-tone="<%= column.tone %>">
            <header class="asana-group-header">
              <div class="asana-group-heading">
                <span class="asana-group-mark"></span>
                <h2><%= column.title %></h2>
                <span class="asana-group-count"><%= column.cards.length %></span>
              </div>
              <p><%= column.subtitle %></p>
            </header>

            <% if (column.cards.length === 0) { %>
              <div class="asana-empty-state">
                <%= column.emptyMessage || "Bu kolona gelecek kart verisini paylaştığınızda burada göstereceğim." %>
              </div>
            <% } else { %>
              <div class="asana-list-table">
                <div class="asana-list-row asana-list-head">
                  <span>Durum</span>
                  <span>Jira</span>
                  <span>Task</span>
                  <span>Epic / Task</span>
                </div>

                <% column.cards.forEach((card) => { %>
                  <article class="asana-list-row asana-list-item">
                    <div class="asana-list-status">
                      <span class="asana-status-pill" data-tone="<%= column.tone %>">
                        <span class="asana-status-dot"></span>
                        <span><%= card.status %></span>
                      </span>
                    </div>

                    <div class="asana-list-key">
                      <% if (card.issueUrl) { %>
                        <a class="asana-key-link" href="<%= card.issueUrl %>" target="_blank" rel="noopener noreferrer"><%= card.key %></a>
                      <% } else { %>
                        <span class="asana-key-link"><%= card.key %></span>
                      <% } %>
                    </div>

                    <div class="asana-list-summary">
                      <p><%= card.summary %></p>
                    </div>

                    <div class="asana-list-links">
                      <% if (card.cardLinks && card.cardLinks.length > 0) { %>
                        <% card.cardLinks.slice(0, 2).forEach((link) => { %>
                          <div
                            class="asana-link-card"
                            style="--jira-card-link-bg:<%= link.badgeBackgroundColor || '#F4F5F7' %>;--jira-card-link-border:<%= link.badgeBorderColor || '#DFE1E6' %>;--jira-card-link-text:<%= link.badgeTextColor || '#172B4D' %>;"
                          >
                            <span class="asana-link-label"><%= link.label %></span>
                            <div class="asana-link-body">
                              <% if (link.issueUrl) { %>
                                <a class="asana-link-key" href="<%= link.issueUrl %>" target="_blank" rel="noopener noreferrer"><%= link.key %></a>
                              <% } else { %>
                                <span class="asana-link-key"><%= link.key %></span>
                              <% } %>
                              <span class="asana-link-summary"><%= link.summary %></span>
                            </div>
                          </div>
                        <% }) %>
                      <% } else { %>
                        <span class="asana-link-empty">Bagli epic/task yok</span>
                      <% } %>
                    </div>
                  </article>
                <% }) %>
              </div>
            <% } %>
          </section>
        <% }) %>
      </section>
    </section>
    <script src="/public/app.js" defer></script>
  </body>
</html>
