<!DOCTYPE html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bus Product</title>
    <link rel="icon" href="/public/favicon.png" />
    <link rel="stylesheet" href="/public/styles.css" />
  </head>
  <body class="dashboard layout obus-rule-define-page">
    <%- include("partials/sidebar", { active }) %>

    <section class="content">
      <header class="page-header">
        <div class="page-title">
          <h1>
            <span class="page-title-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24">
                <rect x="4" y="4" width="16" height="16" rx="2"></rect>
                <path d="M8 8h8"></path>
                <path d="M8 12h8"></path>
                <path d="M8 16h5"></path>
              </svg>
            </span>
            <span>Obus Kural Tanımla</span>
          </h1>
          <p>Firma, tarih ve rate alanlarına göre JSON istek ve örnek yanıt oluşturun.</p>
        </div>
        <div class="page-actions">
          <div class="user-pill"><%= user.displayName %></div>
        </div>
      </header>

      <% if (partnerError) { %>
        <div class="alert inline-alert"><%= partnerError %></div>
      <% } %>

      <section class="table-card panel-card obus-rule-define-page-card">
        <div
          class="obus-rule-define-workbench"
          data-obus-rule-define-page="1"
          data-obus-rule-create-base-url="<%= ruleCreateBaseUrl || '' %>"
          data-obus-rule-submit-url="/api/obus-rule-define/create"
        >
          <aside class="obus-rule-define-title-card">
            <h2>Kural Ekle</h2>
          </aside>

          <section class="obus-rule-define-config-card">
            <input
              type="hidden"
              id="obus-rule-selected-companies"
              value="<%= selectedCompaniesJson || '[]' %>"
            />

            <label class="obus-rule-define-field">
              <span>IsAbroad Filtresi</span>
              <select id="obus-rule-isabroad-filter">
                <option value="all" <%= filters?.isAbroad === 'all' ? 'selected' : '' %>>Hepsi</option>
                <option value="true" <%= filters?.isAbroad === 'true' ? 'selected' : '' %>>true</option>
                <option value="false" <%= filters?.isAbroad === 'false' ? 'selected' : '' %>>false</option>
              </select>
            </label>

            <label class="obus-rule-define-field obus-rule-define-field-company">
              <span>Firmalar</span>
              <div class="obus-company-multiselect">
                <button
                  type="button"
                  class="obus-company-trigger"
                  id="obus-rule-company-trigger"
                  aria-haspopup="listbox"
                  aria-expanded="false"
                >
                  Firma seçiniz
                </button>

                <div class="obus-company-dropdown" id="obus-rule-company-dropdown" role="listbox" hidden>
                  <% if (companyOptions.length > 0) { %>
                    <label class="obus-company-option obus-company-option-all">
                      <input type="checkbox" data-obus-rule-select-all="1" />
                      <span>Hepsi</span>
                    </label>

                    <% companyOptions.forEach((company) => { %>
                      <label class="obus-company-option" data-obus-rule-company-option-row="1">
                        <input
                          type="checkbox"
                          data-obus-rule-company-checkbox="1"
                          value="<%= company.value %>"
                          data-company-label="<%= company.label %>"
                          data-company-code="<%= company.code %>"
                          data-company-id="<%= company.id %>"
                          data-company-cluster="<%= company.cluster %>"
                          data-company-branch-id="<%= company.branchId %>"
                          data-company-url="<%= company.url %>"
                          data-company-isabroad="<%= company.isAbroad || '' %>"
                        />
                        <span><%= company.label %></span>
                      </label>
                    <% }) %>
                    <div class="obus-rule-define-company-empty" data-obus-rule-company-filter-empty="1" hidden>
                      Seçilen IsAbroad filtresine uygun firma bulunamadı.
                    </div>
                  <% } else { %>
                    <div class="obus-rule-define-company-empty">Tüm Firmalar verisinden gösterilecek firma bulunamadı.</div>
                  <% } %>
                </div>
              </div>
              <small class="muted">Liste Tüm Firmalar ekranındaki SQL verisinden gelir. Çoklu seçim yapılabilir.</small>
            </label>

            <div class="obus-rule-define-input-grid">
              <label class="obus-rule-define-field">
                <span>StartDate</span>
                <input type="date" id="obus-rule-start-date" value="<%= filters?.startDate || '' %>" />
              </label>

              <label class="obus-rule-define-field">
                <span>EndDate</span>
                <input type="date" id="obus-rule-end-date" value="<%= filters?.endDate || '' %>" />
              </label>

              <label class="obus-rule-define-field">
                <span>Rate</span>
                <input
                  type="number"
                  id="obus-rule-rate"
                  step="0.01"
                  min="0"
                  value="<%= filters?.rate || '1' %>"
                  autocomplete="off"
                />
              </label>

              <label class="obus-rule-define-field">
                <span>CapacityBegin</span>
                <input
                  type="number"
                  id="obus-rule-capacity-begin"
                  step="1"
                  min="0"
                  value="<%= filters?.capacityBegin || '1' %>"
                  autocomplete="off"
                />
              </label>

              <label class="obus-rule-define-field">
                <span>CapacityEnd</span>
                <input
                  type="number"
                  id="obus-rule-capacity-end"
                  step="1"
                  min="0"
                  value="<%= filters?.capacityEnd || '3' %>"
                  autocomplete="off"
                />
              </label>
            </div>

            <div class="obus-rule-define-actions">
              <button type="button" class="button-link" data-obus-rule-submit="1">İsteği Gönder</button>
            </div>
          </section>

          <article class="obus-rule-define-io-card obus-rule-define-io-card--body">
            <div class="journey-search-card-head">
              <h3>İstek</h3>
              <span class="pill muted">JSON</span>
            </div>
            <pre class="allowed-lines-debug-pre" data-obus-rule-body-preview>{}</pre>
          </article>

          <article class="obus-rule-define-io-card obus-rule-define-io-card--request">
            <div class="journey-search-card-head">
              <h3>Cevap</h3>
              <span class="pill muted">JSON</span>
            </div>
            <pre class="allowed-lines-debug-pre" data-obus-rule-request-preview>{
  "ok": false,
  "message": "İstek henüz gönderilmedi."
}</pre>
          </article>

          <div class="obus-rule-define-status muted" data-obus-rule-status="1">
            Firma, startDate, endDate, rate ve capacity alanlarını güncelledikçe JSON çıktıları yenilenir.
          </div>
        </div>
      </section>
    </section>

    <script src="/public/app.js" defer></script>
  </body>
</html>
