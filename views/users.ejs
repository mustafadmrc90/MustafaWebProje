<!DOCTYPE html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bus Product</title>
    <link rel="icon" href="/public/favicon.png" />
    <link rel="stylesheet" href="/public/styles.css" />
  </head>
  <body class="dashboard layout users-page">
    <%- include("partials/sidebar", { active }) %>

    <section class="content">
      <header class="page-header">
        <div class="page-title">
          <h1>
            <span class="page-title-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24">
                <path d="M16 21v-2a4 4 0 0 0-4-4H7a4 4 0 0 0-4 4v2"></path>
                <circle cx="9" cy="7" r="4"></circle>
                <path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
              </svg>
            </span>
            <span>Kullanıcılar</span>
          </h1>
          <p>Yetki düzenlemeleri için kullanıcıları yönetin.</p>
        </div>
        <div class="page-actions">
          <div class="user-pill"><%= user.displayName %></div>
        </div>
      </header>
      <%- include("partials/page-screen-log", { screenLogPanel }) %>

      <% if (notice) { %>
        <div class="alert success inline-alert"><%= notice %></div>
      <% } %>

      <% if (error) { %>
        <div class="alert inline-alert"><%= error %></div>
      <% } %>

      <div class="panel-grid users-page-grid">
        <section class="table-card panel-card users-create-card">
          <h2>Yeni Kullanıcı</h2>
          <form class="form-grid" method="post" action="/users">
            <label>
              <span>Kullanıcı Adı</span>
              <input type="text" name="username" required />
            </label>
            <label>
              <span>Görünen İsim</span>
              <input type="text" name="displayName" required />
            </label>
            <label>
              <span>Şifre</span>
              <input type="password" name="password" required />
            </label>
            <button type="submit">Kullanıcı Ekle</button>
          </form>
        </section>

        <section class="table-card panel-card users-list-card">
          <div class="table-head">
            <h2>Mevcut Kullanıcılar</h2>
          </div>
          <div class="table users-table">
            <div class="row head users-main-row">
              <span>Kullanıcı</span>
              <span>Görünen İsim</span>
              <span>İşlemler</span>
            </div>
            <% users.forEach((u) => { %>
              <% const deviceItems = userLoginDevicesByUserId && typeof userLoginDevicesByUserId.get === "function" ? (userLoginDevicesByUserId.get(Number(u.id)) || []) : []; %>
              <% const approvedDeviceCount = deviceItems.filter((device) => device.approved).length; %>
              <% const isDevicesExpanded = expandedDeviceUserId === u.id; %>
              <div class="row users-main-row">
                <span>@<%= u.username %></span>
                <span><%= u.display_name %></span>
                <span class="user-row-actions">
                  <form class="user-login-lock-form" method="post" action="/users/<%= u.id %>/login-lock">
                    <input type="hidden" name="enabled" value="0" />
                    <label class="user-login-lock-toggle">
                      <input
                        type="checkbox"
                        name="enabled"
                        value="1"
                        data-user-login-lock-toggle="1"
                        <%= u.login_input_lock_enabled ? 'checked' : '' %>
                      />
                      <span>Login Sabitle</span>
                    </label>
                  </form>
                  <form
                    class="user-login-lock-form"
                    method="post"
                    action="/users/<%= u.id %>/allowed-computer"
                    data-user-ajax-form="allowed-computer"
                  >
                    <input type="hidden" name="enabled" value="0" />
                    <label class="user-login-lock-toggle">
                      <input
                        type="checkbox"
                        name="enabled"
                        value="1"
                        data-user-device-approval-required-toggle="1"
                        <%= u.allowed_computer_enabled ? 'checked' : '' %>
                      />
                      <span>Cihaz Onayı Zorunlu</span>
                    </label>
                  </form>
                  <button
                    type="button"
                    class="button-link ghost"
                    data-user-device-panel-toggle="1"
                    data-user-device-panel-target="<%= u.id %>"
                    aria-expanded="<%= isDevicesExpanded ? 'true' : 'false' %>"
                  >
                    Cihazlar (<%= deviceItems.length %>)
                  </button>
                  <a class="button-link ghost" href="/permissions/<%= u.id %>">Yetkiler</a>
                  <% if (editingUserId === u.id) { %>
                    <a class="button-link ghost" href="/users">Vazgeç</a>
                  <% } else { %>
                    <a class="button-link ghost" href="/users?edit=<%= u.id %>">Düzenle</a>
                  <% } %>
                </span>
              </div>

              <div
                class="row user-device-row"
                data-user-device-panel="<%= u.id %>"
                <%= isDevicesExpanded ? '' : 'hidden' %>
              >
                <div class="user-device-panel">
                  <div class="user-device-panel-head">
                    <div>
                      <strong>Cihaz Onay Listesi</strong>
                      <p>Bu kullanıcı için giriş deneyen cihazların IP ve MAC kayıtları.</p>
                      <% if (u.allowed_computer_enabled) { %>
                        <p class="muted">
                          Cihaz Onayı açıkken login ancak aşağıdaki listede onay verilen aynı IP ve MAC kaydı ile başarılı olur.
                        </p>
                      <% } %>
                    </div>
                    <span class="pill muted"><%= deviceItems.length %> cihaz</span>
                    <span class="pill muted"><%= approvedDeviceCount %> onaylı</span>
                  </div>

                  <% if (deviceItems.length === 0) { %>
                    <div class="user-device-empty">
                      Henüz bu kullanıcı için kayıtlı giriş denemesi yok.
                    </div>
                  <% } else { %>
                    <div class="user-device-list">
                      <% deviceItems.forEach((device) => { %>
                        <form
                          class="user-device-item"
                          method="post"
                          action="/users/<%= u.id %>/login-devices/<%= device.id %>/update"
                          data-user-ajax-form="device-permission"
                        >
                          <div class="user-device-item-main">
                            <div class="user-device-item-values">
                              <span><strong>IP</strong><code><%= device.ipAddress || '-' %></code></span>
                              <span><strong>MAC</strong><code><%= device.macAddress || '-' %></code></span>
                            </div>
                            <div class="user-device-item-meta">
                              <span class="pill <%= device.approved ? '' : 'muted' %>">
                                <%= device.approved ? 'Onaylı' : 'Onay Bekliyor' %>
                              </span>
                              <span class="pill user-device-result-pill is-<%= device.lastLoginResult %>">
                                <%= device.lastLoginResultText %>
                              </span>
                              <span>Son Deneme: <%= device.lastAttemptAtText %></span>
                            </div>
                            <% if (device.lastUserAgent) { %>
                              <div class="user-device-item-agent"><%= device.lastUserAgent %></div>
                            <% } %>
                          </div>

                          <div class="user-device-permission-grid">
                            <input type="hidden" name="approved" value="0" />
                            <label class="user-login-lock-toggle <%= device.ipAddress || device.macAddress ? '' : 'is-disabled' %>">
                              <input
                                type="checkbox"
                                name="approved"
                                value="1"
                                data-user-device-permission-toggle="1"
                                <%= device.approved ? 'checked' : '' %>
                                <%= device.ipAddress || device.macAddress ? '' : 'disabled' %>
                              />
                              <span>Cihaza İzin Ver</span>
                            </label>
                          </div>
                        </form>
                      <% }) %>
                    </div>
                  <% } %>
                </div>
              </div>

              <% if (editingUserId === u.id) { %>
                <div class="row user-edit-row">
                  <form class="user-edit-form" method="post" action="/users/<%= u.id %>/update">
                    <div class="user-edit-fields">
                      <label>
                        <span>Kullanıcı Adı</span>
                        <input type="text" name="username" value="<%= u.username %>" required />
                      </label>
                      <label>
                        <span>Görünen İsim</span>
                        <input type="text" name="displayName" value="<%= u.display_name %>" required />
                      </label>
                      <label>
                        <span>Yeni Şifre (Opsiyonel)</span>
                        <input type="password" name="password" autocomplete="new-password" />
                      </label>
                    </div>
                    <div class="user-edit-actions">
                      <button type="submit">Kaydet</button>
                      <a class="button-link ghost" href="/users">İptal</a>
                    </div>
                  </form>
                </div>
              <% } %>
            <% }) %>
          </div>
        </section>
      </div>
    </section>

    <div class="modal-backdrop user-feedback-backdrop" data-user-feedback-backdrop hidden aria-hidden="true">
      <div class="modal user-feedback-modal" role="dialog" aria-modal="true" aria-labelledby="user-feedback-title">
        <div class="modal-header">
          <h2 id="user-feedback-title">Bilgi</h2>
        </div>
        <p class="user-feedback-message" data-user-feedback-message></p>
        <div class="user-feedback-actions">
          <button type="button" class="button-link" data-user-feedback-close="1">Tamam</button>
        </div>
      </div>
    </div>

    <script src="/public/app.js" defer></script>
    <script src="/public/users.js?v=20260513-2" defer></script>
  </body>
</html>
