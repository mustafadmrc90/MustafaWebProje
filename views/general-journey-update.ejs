<!DOCTYPE html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bus Product</title>
    <link rel="icon" href="/public/favicon.png" />
    <link rel="stylesheet" href="/public/styles.css" />
  </head>
  <body class="dashboard layout">
    <%- include("partials/sidebar", { active }) %>

    <section class="content">
      <header class="page-header">
        <div class="page-title">
          <h1>
            <span class="page-title-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24">
                <path d="M4 7h10"></path>
                <path d="M4 12h8"></path>
                <path d="M4 17h12"></path>
                <path d="M16 6l4 4"></path>
                <path d="M14 16l6-6"></path>
                <path d="M13 19l2-1 5-5"></path>
              </svg>
            </span>
            <span>Sefer Güncelleme</span>
          </h1>
          <p>Seçilen firmanın cluster bilgisiyle günlük sefer özetlerini getirir ve tarih aralığını gün gün tarar.</p>
        </div>
        <div class="page-actions">
          <div class="user-pill"><%= user.displayName %></div>
        </div>
      </header>

      <% if (partnerError) { %>
        <div class="alert inline-alert"><%= partnerError %></div>
      <% } %>

      <section class="table-card panel-card allowed-lines-section">
        <div class="table-head">
          <h2>İstek Parametreleri</h2>
        </div>

        <form
          class="allowed-lines-form"
          method="post"
          action="/general/journey-update"
          data-company-source-url="<%= companySourceBaseUrl || '' %>"
        >
          <input
            type="hidden"
            name="endpointUrl"
            id="allowed-lines-endpoint-url"
            value="<%= filters.endpointUrl || '' %>"
          />
          <input type="hidden" name="submitAction" id="allowed-lines-submit-action" value="journey-update" />
          <div class="allowed-lines-grid">
            <label class="allowed-lines-field allowed-lines-field-company">
              <span>Firma</span>
              <select name="company" id="allowed-lines-company" required>
                <% companies.forEach((company) => { %>
                  <option
                    value="<%= company.value %>"
                    data-cluster="<%= company.meta && company.meta.cluster ? company.meta.cluster : '' %>"
                    <%= filters.company === company.value ? "selected" : "" %>
                    <%= company.disabled ? "disabled" : "" %>
                  >
                    <%= company.label %>
                  </option>
                <% }) %>
              </select>
            </label>
            <label class="allowed-lines-field allowed-lines-field-username">
              <span>Kullanıcı Adı</span>
              <input type="text" name="username" value="<%= filters.username || '' %>" required />
            </label>
            <label class="allowed-lines-field allowed-lines-field-password">
              <span>Şifre</span>
              <input type="password" name="password" value="<%= filters.password || '' %>" required />
            </label>
            <label class="allowed-lines-field">
              <span>Baş Tar</span>
              <input type="date" name="startDate" value="<%= filters.startDate || '' %>" required />
            </label>
            <label class="allowed-lines-field">
              <span>Bit Tar</span>
              <input type="date" name="endDate" value="<%= filters.endDate || '' %>" required />
            </label>
            <label class="allowed-lines-field allowed-lines-field-url">
              <span>İstek URL</span>
              <input
                type="text"
                value="<%= filters.endpointUrl || '' %>"
                data-endpoint-preview
                placeholder="Firma seçildiğinde URL burada oluşur"
                readonly
              />
            </label>
          </div>
          <div class="allowed-lines-actions">
            <button
              type="submit"
              data-submit-action="journey-update"
              data-default-label="Seferleri Göster"
              data-loading-label="Hazırlanıyor..."
            >
              Seferleri Göster
            </button>
          </div>
          <div class="allowed-lines-loading-message" hidden>İstek hazırlanıyor, lütfen bekleyin...</div>
        </form>

        <% if (report.requested && report.error) { %>
          <div class="alert inline-alert"><%= report.error %></div>
        <% } %>
      </section>

      <section class="table-card panel-card allowed-lines-response">
        <div class="table-head">
          <h2>Yanıt</h2>
          <div class="table-actions">
            <% if (report.requested) { %>
              <span class="pill"><%= report.status ? `HTTP ${report.status}` : "HTTP -" %></span>
            <% } else { %>
              <span class="pill muted">Henüz istek atılmadı</span>
            <% } %>
          </div>
        </div>
        <div class="allowed-lines-public-result">
          <% if (report.requested && !report.error && report.userMessage) { %>
            <div class="inline-success"><%= report.userMessage %></div>
          <% } else if (report.requested && report.error) { %>
            <div class="alert inline-alert"><%= report.error %></div>
          <% } else { %>
            <div class="pill muted">Henüz sonuç yok.</div>
          <% } %>
        </div>
        <% if (report.requested && report.requestUrl) { %>
          <div class="allowed-lines-request-url">
            <div class="label">İstek URL</div>
            <pre class="allowed-lines-debug-pre"><%= report.requestUrl %></pre>
          </div>
        <% } %>
        <% if (report.requested) { %>
          <div class="allowed-lines-result-grid">
            <div class="allowed-lines-result-item">
              <div class="label">İstek Body</div>
              <pre class="allowed-lines-debug-pre"><%= report.requestBody || "{}" %></pre>
            </div>
            <div class="allowed-lines-result-item">
              <div class="label"><%= report.error ? "Hata Detayı / Yanıt" : "Yanıt" %></div>
              <pre class="allowed-lines-debug-pre"><%= report.errorDetail || report.responseBody || "-" %></pre>
            </div>
          </div>
        <% } %>
      </section>

      <% if (report.requested) { %>
        <%
          const journeyColumns = Array.isArray(report.tableColumns) ? report.tableColumns : [];
          const updateEditorFields = Array.isArray(journeyUpdateEditorFields) ? journeyUpdateEditorFields : [];
          const showJourneyUpdateEditor = Array.isArray(report.tableRows) && report.tableRows.length > 0;
        %>
        <% if (showJourneyUpdateEditor) { %>
          <section class="table-card panel-card journey-update-editor-card">
            <div class="table-head">
              <h2>Güncelleme Alanları</h2>
              <div class="table-actions">
                <span class="pill muted" data-journey-update-preview-count="1"><%= Array.isArray(report.tableRows) ? report.tableRows.length : 0 %> istek</span>
              </div>
            </div>
            <form
              class="journey-update-editor-form"
              method="post"
              action="/general/journey-update"
              data-journey-update-editor-form="1"
              data-journey-update-endpoint-url="<%= report.updateEndpointUrl || '' %>"
              data-journey-update-request-date="<%= report.updateRequestDate || '' %>"
            >
              <input type="hidden" name="submitAction" value="journey-update-apply" />
              <input type="hidden" name="company" value="<%= filters.company || '' %>" />
              <input type="hidden" name="username" value="<%= filters.username || '' %>" />
              <input type="hidden" name="password" value="<%= filters.password || '' %>" />
              <input type="hidden" name="startDate" value="<%= filters.startDate || '' %>" />
              <input type="hidden" name="endDate" value="<%= filters.endDate || '' %>" />
              <input type="hidden" name="journeyIds" value="<%= report.updateJourneyIdsCsv || '' %>" data-journey-update-row-ids="1" />
              <input type="hidden" name="detailState" value="<%= report.updateDetailState || '' %>" data-journey-update-detail-state="1" />
              <input type="hidden" name="tableRowsState" value="<%= report.tableRowsState || '' %>" />
              <input type="hidden" name="tableColumnsState" value="<%= report.tableColumnsState || '' %>" />

              <div class="journey-update-editor-grid">
                <% updateEditorFields.forEach((field) => { %>
                  <label class="journey-update-editor-field">
                    <span><%= field.label %></span>
                    <% if (field.inputType === "select") { %>
                      <select
                        name="<%= `update_${field.key}` %>"
                        data-journey-update-editor-key="<%= field.key %>"
                        data-journey-update-param-type="<%= field.parameterType %>"
                        data-journey-update-value-type="<%= field.valueType %>"
                      >
                        <option value="">Seçiniz</option>
                        <option value="true" <%= field.value === "true" ? "selected" : "" %>>Evet</option>
                        <option value="false" <%= field.value === "false" ? "selected" : "" %>>Hayır</option>
                      </select>
                    <% } else { %>
                      <input
                        type="<%= field.inputType %>"
                        name="<%= `update_${field.key}` %>"
                        value="<%= field.value || '' %>"
                        data-journey-update-editor-key="<%= field.key %>"
                        data-journey-update-param-type="<%= field.parameterType %>"
                        data-journey-update-value-type="<%= field.valueType %>"
                        placeholder="Değer girin"
                        <% if (field.step) { %>step="<%= field.step %>"<% } %>
                        <% if (field.min) { %>min="<%= field.min %>"<% } %>
                      />
                    <% } %>
                  </label>
                <% }) %>
              </div>

              <div class="journey-update-editor-preview-grid">
                <div class="journey-update-editor-preview-item">
                  <div class="label">İstek URL</div>
                  <pre class="allowed-lines-debug-pre" data-journey-update-request-url><%= report.updateEndpointUrl || "-" %></pre>
                </div>
                <div class="journey-update-editor-preview-item">
                  <div class="label">Header</div>
                  <pre class="allowed-lines-debug-pre" data-journey-update-request-headers><%= report.updateRequestHeaders || "{}" %></pre>
                </div>
                <div class="journey-update-editor-preview-item journey-update-editor-preview-item--body">
                  <div class="label">İstek Body</div>
                  <pre class="allowed-lines-debug-pre" data-journey-update-request-body><%= report.updateRequestBodyPreview || "{}" %></pre>
                </div>
              </div>

              <div class="allowed-lines-actions journey-update-editor-actions">
                <button type="submit" data-default-label="Seferleri Güncelle" data-loading-label="Gönderiliyor...">
                  Seferleri Güncelle
                </button>
              </div>
              <div class="allowed-lines-loading-message journey-update-editor-loading" hidden>
                UpdateJourney istekleri hazırlanıyor, lütfen bekleyin...
              </div>
            </form>
          </section>
        <% } %>
        <section class="table-card panel-card journey-update-table-card" data-journey-update-card="1">
          <div class="table-head">
            <h2>Sefer Listesi</h2>
            <div class="table-actions">
              <span class="pill" data-journey-update-count="1"><%= Array.isArray(report.tableRows) ? report.tableRows.length : 0 %> satır</span>
              <button type="button" class="button-link journey-update-filter-clear" data-journey-clear-filters="1">
                Filtreleri Temizle
              </button>
            </div>
          </div>
          <% if (Array.isArray(report.tableRows) && report.tableRows.length) { %>
            <div class="journey-update-floating-scroll" data-journey-floating-scroll="1" hidden>
              <div class="journey-update-floating-scroll-track" data-journey-floating-scroll-track="1"></div>
            </div>
            <div class="table-scroll" data-journey-table-scroll="1">
              <table class="partners-raw-table" data-journey-update-table="1">
                <thead>
                  <tr>
                    <% journeyColumns.forEach((column) => { %>
                      <th>
                        <div class="journey-update-column-filter">
                          <div class="journey-update-column-head">
                            <span><%= column.label %></span>
                            <button
                              type="button"
                              class="journey-update-sort-button"
                              data-journey-sort-key="<%= column.key %>"
                              data-journey-sort-type="<%= column.sortType %>"
                              data-sort-direction=""
                              aria-label="<%= `${column.label} kolonunu sirala` %>"
                              title="Sırala"
                            >
                              ↕
                            </button>
                          </div>
                          <% if (column.filterType === "select") { %>
                            <select data-journey-filter-key="<%= column.key %>" data-journey-filter-match="exact">
                              <option value="">Tümü</option>
                              <% (column.options || []).forEach((optionValue) => { %>
                                <option value="<%= optionValue %>"><%= optionValue %></option>
                              <% }) %>
                            </select>
                          <% } else if (column.filterType === "date") { %>
                            <input
                              type="date"
                              data-journey-filter-key="<%= column.key %>"
                              data-journey-filter-type="date"
                            />
                          <% } else { %>
                            <input type="text" data-journey-filter-key="<%= column.key %>" placeholder="Ara" />
                          <% } %>
                        </div>
                      </th>
                    <% }) %>
                  </tr>
                </thead>
                <tbody>
                  <% report.tableRows.forEach((row) => { %>
                    <tr>
                      <% journeyColumns.forEach((column) => { %>
                        <td data-journey-cell="<%= column.key %>"><%= row[column.key] || "-" %></td>
                      <% }) %>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
            <div class="pill muted journey-update-empty-result" data-journey-update-empty="1" hidden>
              Filtreye uygun kayıt bulunamadı.
            </div>
          <% } else if (report.error) { %>
            <div class="pill muted">Satır listesi oluşturulamadı.</div>
          <% } else { %>
            <div class="pill muted">Seçilen tarih aralığında listelenecek sefer bulunamadı.</div>
          <% } %>
        </section>
      <% } %>
    </section>
    <script src="/public/app.js" defer></script>
  </body>
</html>
