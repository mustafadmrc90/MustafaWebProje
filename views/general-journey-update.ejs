<!DOCTYPE html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bus Product</title>
    <link rel="icon" href="/public/favicon.png" />
    <link rel="stylesheet" href="/public/styles.css" />
  </head>
  <body class="dashboard layout">
    <%- include("partials/sidebar", { active }) %>

    <section class="content">
      <header class="page-header">
        <div class="page-title">
          <h1>
            <span class="page-title-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24">
                <path d="M4 7h10"></path>
                <path d="M4 12h8"></path>
                <path d="M4 17h12"></path>
                <path d="M16 6l4 4"></path>
                <path d="M14 16l6-6"></path>
                <path d="M13 19l2-1 5-5"></path>
              </svg>
            </span>
            <span>Sefer Güncelleme</span>
          </h1>
          <p>Seçilen firmanın cluster bilgisiyle günlük sefer özetlerini getirir ve tarih aralığını gün gün tarar.</p>
        </div>
        <div class="page-actions">
          <div class="user-pill"><%= user.displayName %></div>
        </div>
      </header>

      <% if (partnerError) { %>
        <div class="alert inline-alert"><%= partnerError %></div>
      <% } %>

      <section class="table-card panel-card allowed-lines-section">
        <div class="table-head">
          <h2>İstek Parametreleri</h2>
        </div>

        <form
          class="allowed-lines-form"
          method="post"
          action="/general/journey-update"
          data-company-source-url="<%= companySourceBaseUrl || '' %>"
        >
          <input
            type="hidden"
            name="endpointUrl"
            id="allowed-lines-endpoint-url"
            value="<%= filters.endpointUrl || '' %>"
          />
          <input type="hidden" name="submitAction" id="allowed-lines-submit-action" value="journey-update" />
          <div class="allowed-lines-grid">
            <label class="allowed-lines-field allowed-lines-field-company">
              <span>Firma</span>
              <select name="company" id="allowed-lines-company" required>
                <% companies.forEach((company) => { %>
                  <option
                    value="<%= company.value %>"
                    data-cluster="<%= company.meta && company.meta.cluster ? company.meta.cluster : '' %>"
                    <%= filters.company === company.value ? "selected" : "" %>
                    <%= company.disabled ? "disabled" : "" %>
                  >
                    <%= company.label %>
                  </option>
                <% }) %>
              </select>
            </label>
            <label class="allowed-lines-field allowed-lines-field-username">
              <span>Kullanıcı Adı</span>
              <input type="text" name="username" value="<%= filters.username || '' %>" required />
            </label>
            <label class="allowed-lines-field allowed-lines-field-password">
              <span>Şifre</span>
              <input type="password" name="password" value="<%= filters.password || '' %>" required />
            </label>
            <label class="allowed-lines-field">
              <span>Baş Tar</span>
              <input type="date" name="startDate" value="<%= filters.startDate || '' %>" required />
            </label>
            <label class="allowed-lines-field">
              <span>Bit Tar</span>
              <input type="date" name="endDate" value="<%= filters.endDate || '' %>" required />
            </label>
            <label class="allowed-lines-field allowed-lines-field-url">
              <span>İstek URL</span>
              <input
                type="text"
                value="<%= filters.endpointUrl || '' %>"
                data-endpoint-preview
                placeholder="Firma seçildiğinde URL burada oluşur"
                readonly
              />
            </label>
          </div>
          <div class="allowed-lines-actions">
            <button
              type="submit"
              data-submit-action="journey-update"
              data-default-label="Seferleri Göster"
              data-loading-label="Hazırlanıyor..."
            >
              Seferleri Göster
            </button>
          </div>
          <div class="allowed-lines-loading-message" hidden>İstek hazırlanıyor, lütfen bekleyin...</div>
        </form>

        <% if (report.requested && report.error) { %>
          <div class="alert inline-alert"><%= report.error %></div>
        <% } %>
      </section>

      <section class="table-card panel-card allowed-lines-response">
        <div class="table-head">
          <h2>Yanıt</h2>
          <div class="table-actions">
            <% if (report.requested) { %>
              <span class="pill"><%= report.status ? `HTTP ${report.status}` : "HTTP -" %></span>
            <% } else { %>
              <span class="pill muted">Henüz istek atılmadı</span>
            <% } %>
          </div>
        </div>
        <div class="allowed-lines-public-result">
          <% if (report.requested && !report.error && report.userMessage) { %>
            <div class="inline-success"><%= report.userMessage %></div>
          <% } else if (report.requested && report.error) { %>
            <div class="alert inline-alert"><%= report.error %></div>
          <% } else { %>
            <div class="pill muted">Henüz sonuç yok.</div>
          <% } %>
        </div>
        <% if (report.requested && report.requestUrl) { %>
          <div class="allowed-lines-request-url">
            <div class="label">İstek URL</div>
            <pre class="allowed-lines-debug-pre"><%= report.requestUrl %></pre>
          </div>
        <% } %>
        <% if (report.requested) { %>
          <div class="allowed-lines-result-grid">
            <div class="allowed-lines-result-item">
              <div class="label">İstek Body</div>
              <pre class="allowed-lines-debug-pre"><%= report.requestBody || "{}" %></pre>
            </div>
            <div class="allowed-lines-result-item">
              <div class="label"><%= report.error ? "Hata Detayı / Yanıt" : "Yanıt" %></div>
              <pre class="allowed-lines-debug-pre"><%= report.errorDetail || report.responseBody || "-" %></pre>
            </div>
          </div>
        <% } %>
      </section>

      <% if (report.requested) { %>
        <section class="table-card panel-card journey-update-table-card">
          <div class="table-head">
            <h2>Sefer Listesi</h2>
            <div class="table-actions">
              <span class="pill"><%= Array.isArray(report.tableRows) ? report.tableRows.length : 0 %> satır</span>
            </div>
          </div>
          <% if (Array.isArray(report.tableRows) && report.tableRows.length) { %>
            <div class="table-scroll">
              <table class="partners-raw-table">
                <thead>
                  <tr>
                    <th>Tarih</th>
                    <th>Firma</th>
                    <th>PartnerId</th>
                    <th>Cluster</th>
                    <th>SeferId</th>
                    <th>Kalkış</th>
                    <th>Güzergah</th>
                    <th>Plaka</th>
                  </tr>
                </thead>
                <tbody>
                  <% report.tableRows.forEach((row) => { %>
                    <tr>
                      <td><%= row.requestDate || '-' %></td>
                      <td><%= row.companyCode || '-' %></td>
                      <td><%= row.partnerId || '-' %></td>
                      <td><%= row.cluster || '-' %></td>
                      <td><%= row.journeyId || '-' %></td>
                      <td><%= row.departureTime || '-' %></td>
                      <td><%= row.routeInfo || '-' %></td>
                      <td><%= row.plate || '-' %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } else if (report.error) { %>
            <div class="pill muted">Satır listesi oluşturulamadı.</div>
          <% } else { %>
            <div class="pill muted">Seçilen tarih aralığında listelenecek sefer bulunamadı.</div>
          <% } %>
        </section>
      <% } %>
    </section>
    <script src="/public/app.js" defer></script>
  </body>
</html>
