<!DOCTYPE html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bus Product</title>
    <link rel="icon" href="/public/favicon.png" />
    <link rel="stylesheet" href="/public/styles.css" />
  </head>
  <body class="dashboard layout station-passenger-info-page">
    <%- include("partials/sidebar", { active }) %>

    <section class="content">
      <div class="station-passenger-mobile-shell" data-station-passenger-page="1">
        <section class="station-passenger-mobile-screen">
          <header class="page-header">
            <div class="page-title">
              <h1>
                <span class="page-title-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24">
                    <path d="M6 18v-6a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v6"></path>
                    <path d="M4 18h16"></path>
                    <path d="M8 10V6"></path>
                    <path d="M16 10V6"></path>
                    <path d="M8 6h8"></path>
                    <circle cx="12" cy="14" r="2"></circle>
                  </svg>
                </span>
                <span>Durak Yolcu Bilgisi</span>
              </h1>
            </div>
          </header>

          <section class="table-card panel-card station-passenger-plate-card">
            <label class="station-passenger-field" for="station-passenger-plate">
              <span class="station-passenger-field-label">Plaka</span>
              <div class="station-passenger-field-row">
                <input
                  type="text"
                  id="station-passenger-plate"
                  name="plate"
                  placeholder="34 ABC 123"
                  autocomplete="off"
                  autocapitalize="characters"
                  spellcheck="false"
                  inputmode="text"
                  data-station-passenger-plate-input
                />
                <button type="button" class="button-link station-passenger-go-button" data-station-passenger-go-button>
                  Sefere Git
                </button>
              </div>
            </label>
          </section>

          <section class="table-card panel-card station-passenger-results-card">
            <div class="station-passenger-results-head">
              <h2>Seferler</h2>
              <span class="pill muted" data-station-passenger-results-count>0</span>
            </div>
            <div class="station-passenger-results-status muted" data-station-passenger-status>
              Plakayı yazıp Sefere Git butonuna basın.
            </div>
            <div class="station-passenger-results-list" data-station-passenger-results-list>
              <div class="station-passenger-results-empty">Henüz listelenecek sefer yok.</div>
            </div>
          </section>

          <section class="table-card panel-card station-passenger-next-stop-card" data-station-passenger-next-stop-section hidden>
            <div class="station-passenger-results-head">
              <h2>Durak</h2>
            </div>
            <div class="station-passenger-next-stop" data-station-passenger-next-stop>
              <div class="station-passenger-next-stop-head">
                <span class="station-passenger-next-stop-badge" data-station-passenger-next-stop-order>-</span>
                <div class="station-passenger-next-stop-meta">
                  <strong data-station-passenger-next-stop-station>-</strong>
                  <span data-station-passenger-next-stop-request-time>-</span>
                </div>
              </div>
              <div class="station-passenger-next-stop-time" data-station-passenger-next-stop-departure>-</div>
            </div>
          </section>

          <section class="table-card panel-card station-passenger-passenger-card" data-station-passenger-passenger-section hidden>
            <div class="station-passenger-results-head">
              <h2>Yolcular</h2>
            </div>
            <div class="station-passenger-passenger-state" data-station-passenger-passenger-state>
              <section class="station-passenger-passenger-group">
                <div class="station-passenger-passenger-group-head">
                  <h3>Binecek Yolcular</h3>
                  <span class="pill muted" data-station-passenger-boarding-count>0</span>
                </div>
                <div class="station-passenger-passenger-list" data-station-passenger-boarding-list></div>
              </section>

              <section class="station-passenger-passenger-group">
                <div class="station-passenger-passenger-group-head">
                  <h3>İnecek Yolcular</h3>
                  <span class="pill muted" data-station-passenger-dropoff-count>0</span>
                </div>
                <div class="station-passenger-passenger-list" data-station-passenger-dropoff-list></div>
              </section>
            </div>
          </section>
        </section>
      </div>
    </section>
    <script src="/public/app.js" defer></script>
  </body>
</html>
