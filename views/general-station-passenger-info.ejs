<!DOCTYPE html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bus Product</title>
    <link rel="icon" href="/public/favicon.png" />
    <link rel="stylesheet" href="/public/styles.css" />
  </head>
  <body class="dashboard layout station-passenger-info-page">
    <%- include("partials/sidebar", { active }) %>

    <section class="content">
      <div class="station-passenger-mobile-shell" data-station-passenger-page="1" data-station-passenger-search-mode="realtime">
        <section class="station-passenger-mobile-screen" data-station-passenger-main-screen>
          <header class="page-header">
            <div class="page-title">
              <h1>
                <span class="page-title-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24">
                    <path d="M6 18v-6a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v6"></path>
                    <path d="M4 18h16"></path>
                    <path d="M8 10V6"></path>
                    <path d="M16 10V6"></path>
                    <path d="M8 6h8"></path>
                    <circle cx="12" cy="14" r="2"></circle>
                  </svg>
                </span>
                <span>Durak Yolcu Bilgisi</span>
              </h1>
            </div>
          </header>
          <%- include("partials/page-screen-log", { screenLogPanel }) %>

          <section class="table-card panel-card station-passenger-mode-card">
            <div
              class="station-passenger-mode-toggle"
              data-station-passenger-mode-toggle
              data-search-mode="realtime"
              role="group"
              aria-label="Durak yolcu bilgisi sorgu modu"
            >
              <span class="station-passenger-mode-toggle-thumb" aria-hidden="true"></span>
              <button
                type="button"
                class="station-passenger-mode-button is-active"
                data-station-passenger-mode-button="realtime"
                aria-pressed="true"
              >
                Gerçek zamanda sorgula
              </button>
              <button
                type="button"
                class="station-passenger-mode-button"
                data-station-passenger-mode-button="all-stations"
                aria-pressed="false"
              >
                Tüm durakları sorgula
              </button>
            </div>
          </section>

          <section class="table-card panel-card station-passenger-plate-card">
            <label class="station-passenger-field" for="station-passenger-plate">
              <span class="station-passenger-field-label">Plaka</span>
              <div class="station-passenger-field-row">
                <input
                  type="text"
                  id="station-passenger-plate"
                  name="plate"
                  placeholder="34 ABC 123"
                  autocomplete="off"
                  autocapitalize="characters"
                  spellcheck="false"
                  inputmode="text"
                  data-station-passenger-plate-input
                />
                <button type="button" class="button-link station-passenger-go-button" data-station-passenger-go-button>
                  Sefere Git
                </button>
              </div>
            </label>
          </section>

          <section class="table-card panel-card station-passenger-results-card">
            <div class="station-passenger-results-head">
              <h2>Seferler</h2>
              <span class="pill muted" data-station-passenger-results-count>0</span>
            </div>
            <div class="station-passenger-results-status muted" data-station-passenger-status>
              Plakayı yazıp Sefere Git butonuna basın.
            </div>
            <div class="station-passenger-results-list" data-station-passenger-results-list>
              <div class="station-passenger-results-empty">Henüz listelenecek sefer yok.</div>
            </div>
          </section>

          <section class="table-card panel-card station-passenger-next-stop-card" data-station-passenger-next-stop-section hidden>
            <div class="station-passenger-results-head">
              <h2>Durak</h2>
            </div>
            <div class="station-passenger-next-stop" data-station-passenger-next-stop>
              <div class="station-passenger-next-stop-head">
                <span class="station-passenger-next-stop-badge" data-station-passenger-next-stop-order>-</span>
                <div class="station-passenger-next-stop-meta">
                  <strong data-station-passenger-next-stop-station>-</strong>
                </div>
              </div>
              <div class="station-passenger-next-stop-time" data-station-passenger-next-stop-departure>-</div>
            </div>
          </section>

          <section class="table-card panel-card station-passenger-passenger-card" data-station-passenger-passenger-section hidden>
            <div class="station-passenger-results-head">
              <h2>Yolcular</h2>
            </div>
            <div class="station-passenger-passenger-state" data-station-passenger-passenger-state>
              <section class="station-passenger-passenger-group">
                <div class="station-passenger-passenger-group-head">
                  <h3>İnecek Yolcular</h3>
                  <span class="pill muted" data-station-passenger-dropoff-count>0</span>
                </div>
                <div class="station-passenger-passenger-list" data-station-passenger-dropoff-list></div>
              </section>

              <section class="station-passenger-passenger-group">
                <div class="station-passenger-passenger-group-head">
                  <h3>Binecek Yolcular</h3>
                  <span class="pill muted" data-station-passenger-boarding-count>0</span>
                </div>
                <div class="station-passenger-passenger-list" data-station-passenger-boarding-list></div>
              </section>
            </div>
          </section>
        </section>

        <section
          class="station-passenger-mobile-screen station-passenger-mobile-screen--secondary"
          data-station-passenger-all-stations-screen
          hidden
        >
          <header class="station-passenger-secondary-head">
            <button
              type="button"
              class="ghost station-passenger-secondary-back"
              data-station-passenger-all-stations-back
            >
              Seferlere Dön
            </button>
            <div class="station-passenger-secondary-title">
              <strong>Tüm Duraklar</strong>
              <span data-station-passenger-all-stations-trip-id>SeferID: -</span>
            </div>
          </header>

          <section class="table-card panel-card station-passenger-all-stations-card">
            <div class="station-passenger-results-head">
              <h2>Duraklar</h2>
              <span class="pill muted" data-station-passenger-all-stations-count>0</span>
            </div>
            <div class="station-passenger-results-status muted" data-station-passenger-all-stations-status>
              Tüm duraklar burada listelenecek.
            </div>
            <div class="station-passenger-all-stations-list" data-station-passenger-all-stations-list>
              <div class="station-passenger-results-empty">Henüz listelenecek durak yok.</div>
            </div>
          </section>
        </section>

        <section
          class="station-passenger-mobile-screen station-passenger-mobile-screen--secondary"
          data-station-passenger-station-detail-screen
          hidden
        >
          <header class="station-passenger-secondary-head">
            <button
              type="button"
              class="ghost station-passenger-secondary-back"
              data-station-passenger-station-detail-back
            >
              Duraklara Dön
            </button>
            <div class="station-passenger-secondary-title">
              <strong>Durak Yolcu Bilgisi</strong>
              <span data-station-passenger-station-detail-trip-id>SeferID: -</span>
            </div>
          </header>

          <section class="table-card panel-card station-passenger-next-stop-card" data-station-passenger-station-detail-section hidden>
            <div class="station-passenger-results-head">
              <h2>Seçilen Durak</h2>
            </div>
            <div class="station-passenger-next-stop" data-station-passenger-station-detail-card>
              <div class="station-passenger-next-stop-head">
                <span class="station-passenger-next-stop-badge" data-station-passenger-station-detail-order>-</span>
                <div class="station-passenger-next-stop-meta">
                  <strong data-station-passenger-station-detail-station>-</strong>
                </div>
              </div>
              <div class="station-passenger-next-stop-time" data-station-passenger-station-detail-departure>-</div>
            </div>
          </section>

          <section
            class="table-card panel-card station-passenger-passenger-card"
            data-station-passenger-station-detail-passenger-section
            hidden
          >
            <div class="station-passenger-results-head">
              <h2>Yolcular</h2>
            </div>
            <div
              class="station-passenger-results-status muted"
              data-station-passenger-station-detail-passenger-status
            >
              Bir durak seçin.
            </div>
            <div class="station-passenger-passenger-state" data-station-passenger-station-detail-passenger-state hidden>
              <section class="station-passenger-passenger-group">
                <div class="station-passenger-passenger-group-head">
                  <h3>İnecek Yolcular</h3>
                  <span class="pill muted" data-station-passenger-station-detail-dropoff-count>0</span>
                </div>
                <div class="station-passenger-passenger-list" data-station-passenger-station-detail-dropoff-list></div>
              </section>

              <section class="station-passenger-passenger-group">
                <div class="station-passenger-passenger-group-head">
                  <h3>Binecek Yolcular</h3>
                  <span class="pill muted" data-station-passenger-station-detail-boarding-count>0</span>
                </div>
                <div class="station-passenger-passenger-list" data-station-passenger-station-detail-boarding-list></div>
              </section>
            </div>
          </section>
        </section>
      </div>
    </section>
    <script src="/public/app.js" defer></script>
  </body>
</html>
