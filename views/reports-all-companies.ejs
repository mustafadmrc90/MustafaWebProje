<!DOCTYPE html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bus Product</title>
    <link rel="icon" href="/public/favicon.png" />
    <link rel="stylesheet" href="/public/styles.css" />
  </head>
  <body class="dashboard layout">
    <%- include("partials/sidebar", { active }) %>

    <section class="content">
      <header class="page-header">
        <div class="page-title">
          <h1>
            <span class="page-title-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24">
                <path d="M4 20h16"></path>
                <rect x="6" y="10" width="4" height="7"></rect>
                <rect x="10" y="7" width="4" height="10"></rect>
                <rect x="14" y="12" width="4" height="5"></rect>
              </svg>
            </span>
            <span>Tüm Firmalar</span>
          </h1>
          <p>Status=1 kayıtlar sabit kolon yapısıyla listelenir.</p>
        </div>
        <div class="page-actions">
          <div class="user-pill"><%= user.displayName %></div>
        </div>
      </header>

      <% if (report.error) { %>
        <div class="alert inline-alert"><%= report.error %></div>
      <% } %>
      <% if (report.sync && report.sync.message) { %>
        <div
          class="<%= report.sync.kind === 'warning' || report.sync.kind === 'error' ? 'alert inline-alert' : 'inline-success' %>"
          <% if (report.sync.job) { %>
            data-all-companies-job="1"
            data-job-id="<%= report.sync.job.id %>"
            data-job-done="<%= report.sync.job.done ? '1' : '0' %>"
            data-refresh-url="<%= report.sync.job.refreshUrl %>"
            data-running-message="<%= report.sync.job.runningMessage %>"
            data-show-counts="<%= report.sync.job.showCounts ? '1' : '0' %>"
          <% } %>
        >
          <%= report.sync.message %>
        </div>
      <% } %>
      <% if (report.save && report.save.message) { %>
        <div class="inline-success"><%= report.save.message %></div>
      <% } %>
      <% if (report.obus && report.obus.message) { %>
        <div
          class="<%= report.obus.kind === 'warning' || report.obus.kind === 'error' ? 'alert inline-alert' : 'inline-success' %>"
          <% if (report.obus.job) { %>
            data-all-companies-job="1"
            data-job-id="<%= report.obus.job.id %>"
            data-job-done="<%= report.obus.job.done ? '1' : '0' %>"
            data-refresh-url="<%= report.obus.job.refreshUrl %>"
            data-running-message="ObusMerkezSubeID güncellemesi sürüyor. Sayfa otomatik yenilenecek..."
            data-show-counts="0"
          <% } %>
        >
          <%= report.obus.message %>
        </div>
      <% } %>
      <% if (report.cache && report.cache.message) { %>
        <div class="inline-success"><%= report.cache.message %></div>
      <% } %>
      <% if (report.notice) { %>
        <p class="muted"><%= report.notice %></p>
      <% } %>

      <section class="table-card panel-card">
        <div class="table-head">
          <h2>Partner Sonuçları</h2>
          <div class="table-actions">
            <span class="pill"><%= report.rows.length %> Kayıt</span>
            <span class="pill"><%= report.columns.length %> Kolon</span>
            <span class="pill"><%= report.clusterCount %> Cluster</span>
            <form class="all-companies-loading-form all-companies-refresh-form" method="get" action="/reports/all-companies">
              <button class="button-link ghost" type="submit" data-default-label="Yenile" data-loading-label="Yükleniyor...">
                Yenile
              </button>
              <span class="all-companies-loading-message" hidden>
                Liste açılıyor...
              </span>
            </form>
            <form class="all-companies-loading-form all-companies-sync-form" method="get" action="/reports/all-companies">
              <input type="hidden" name="sync" value="1" />
              <button class="button-link" type="submit" data-default-label="Servisten Güncelle" data-loading-label="Çalışıyor...">
                Servisten Güncelle
              </button>
              <span class="all-companies-loading-message" hidden>
                Servis verisi çekiliyor...
              </span>
            </form>
            <form
              class="all-companies-loading-form all-companies-obus-sync-form"
              method="post"
              action="/reports/all-companies/update-obus-merkez-sube-id"
            >
              <button
                class="button-link"
                type="submit"
                data-default-label="ObusMerkezSubeID Güncelle"
                data-loading-label="Güncelleniyor..."
              >
                ObusMerkezSubeID Güncelle
              </button>
              <span class="all-companies-loading-message" hidden>
                Sadece boş ObusMerkezSubeID kayıtları güncelleniyor...
              </span>
            </form>
            <form class="all-companies-loading-form all-companies-save-form" method="post" action="/reports/all-companies/save-sql">
              <input type="hidden" name="saveSource" value="<%= report.sync?.hasPreview ? 'service' : 'cache' %>" />
              <button
                class="button-link"
                type="submit"
                data-default-label="SQL'e Kaydet"
                data-loading-label="Kaydediliyor..."
              >
                SQL'e Kaydet
              </button>
              <span class="all-companies-loading-message" hidden>
                Listedeki kayıtlar SQL'e yazılıyor...
              </span>
            </form>
            <form class="all-companies-loading-form all-companies-cache-form" method="get" action="/reports/all-companies">
              <input type="hidden" name="cache" value="1" />
              <button class="button-link ghost" type="submit" data-default-label="SQL'den Göster" data-loading-label="Yükleniyor...">
                SQL'den Göster
              </button>
              <span class="all-companies-loading-message" hidden>
                SQL kayıtları yükleniyor...
              </span>
            </form>
          </div>
        </div>

        <% if (report.columns.length === 0 || report.rows.length === 0) { %>
          <p class="muted">Gösterilecek partner kaydı bulunamadı.</p>
        <% } %>

        <% if (report.columns.length > 0 && report.rows.length > 0) { %>
          <div class="table-scroll">
            <table class="partners-raw-table">
              <thead>
                <tr>
                  <% report.columns.forEach((column) => { %>
                    <th><%= column %></th>
                  <% }) %>
                </tr>
              </thead>
              <tbody>
                <% report.rows.forEach((row) => { %>
                  <tr>
                    <% report.columns.forEach((column) => { %>
                      <% const isObusDebugColumn = column === "ObusMerkezSubeID"; %>
                      <% const rawValue = row[column]; %>
                      <% const debugValue = isObusDebugColumn ? String(row.ObusMerkezSubeIDDebug || "").trim() : ""; %>
                      <% const normalizedValue = rawValue === undefined || rawValue === null ? "" : String(rawValue).trim(); %>
                      <% const displayValue = normalizedValue || debugValue || "-"; %>
                      <td title="<%= displayValue %>"><%= displayValue %></td>
                    <% }) %>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </section>
    </section>
    <script src="/public/app.js" defer></script>
  </body>
</html>
