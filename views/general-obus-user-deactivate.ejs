<!DOCTYPE html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <% if (report?.searchJob && report.searchJob.done === false && report.searchJob.refreshUrl) { %>
      <meta http-equiv="refresh" content="3;url=<%= report.searchJob.refreshUrl %>" />
    <% } %>
    <title>Bus Product</title>
    <link rel="icon" href="/public/favicon.png" />
    <link rel="stylesheet" href="/public/styles.css" />
  </head>
  <body class="dashboard layout">
    <%- include("partials/sidebar", { active }) %>

    <section class="content">
      <header class="page-header">
        <div class="page-title">
          <h1>
            <span class="page-title-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24">
                <path d="M7 12h10"></path>
                <circle cx="12" cy="12" r="9"></circle>
              </svg>
            </span>
            <span>Obus Kullanıcı Pasife Al</span>
          </h1>
          <p>Kullanıcı adına göre tüm clusterlarda kullanıcı listesi taranır.</p>
        </div>
        <div class="page-actions">
          <div class="user-pill"><%= user.displayName %></div>
        </div>
      </header>

      <% if (report && report.error) { %>
        <div class="alert inline-alert"><%= report.error %></div>
      <% } %>

      <section class="table-card panel-card obus-user-deactivate-section">
        <div class="table-head">
          <h2>Kullanıcı Arama</h2>
        </div>

        <form class="obus-user-deactivate-form obus-user-deactivate-search-form" method="get" action="/general/obus-user-deactivate">
          <input type="hidden" name="run" value="1" />

          <div class="obus-user-deactivate-grid">
            <label class="obus-user-create-field">
              <span>KullanıcıAdı</span>
              <input type="text" name="username" value="<%= filters?.username || '' %>" required />
            </label>
          </div>

          <div class="obus-user-create-actions">
            <button class="button-link" type="submit">Kullanıcıları Listele</button>
          </div>

          <div class="obus-user-deactivate-loading-message obus-user-deactivate-search-loading-message" hidden>
            Kullanıcılar clusterlardan getiriliyor...
          </div>
        </form>
      </section>

      <% if (report?.searchJob && report.searchJob.done === false) { %>
        <section class="table-card panel-card obus-user-deactivate-section">
          <div class="table-head">
            <h2>Arama Sürüyor</h2>
          </div>
          <p class="muted">Kullanıcılar clusterlarda taranıyor. Sayfa otomatik yenilenecek.</p>
        </section>
      <% } %>

      <% if (report?.searchDebugNotice) { %>
        <div class="inline-alert"><%= report.searchDebugNotice %></div>
      <% } %>

      <% if (report && report.requested && !(report.searchJob && report.searchJob.done === false)) { %>
        <section class="table-card panel-card obus-user-deactivate-results">
          <form class="obus-user-deactivate-form obus-user-deactivate-delete-form" method="post" action="/general/obus-user-deactivate">
            <input type="hidden" name="username" value="<%= filters?.username || '' %>" />
            <input type="hidden" name="searchJobId" value="<%= report?.searchJob?.id || '' %>" />

              <div class="table-head">
                <h2>Kullanıcı Listesi</h2>
                <div class="table-actions">
                  <span class="pill">Toplam: <%= report.totalCount %></span>
                  <span class="pill">Cluster: <%= report.clusterCount || 0 %></span>
                  <span class="pill" data-obus-live-progress="1">İşlenen: 0/<%= report.totalCount %></span>
                  <span class="pill success" data-obus-live-success="1">Başarılı: 0</span>
                  <span class="pill muted" data-obus-live-failure="1">Hatalı: 0</span>
                  <% if (report.items && report.items.length > 0) { %>
                    <label class="obus-user-deactivate-select-all">
                      <input type="checkbox" data-obus-user-select-all="1" checked />
                    <span>Hepsi</span>
                  </label>
                <% } %>
              </div>
            </div>

            <% if (!report.items || report.items.length === 0) { %>
              <p class="muted">Eşleşen kullanıcı bulunamadı.</p>
            <% } %>

            <% if (report.items && report.items.length > 0) { %>
              <div class="table-scroll obus-user-deactivate-table-scroll">
                <table class="partners-raw-table">
                  <thead>
                    <tr>
                      <th>Seç</th>
                      <th>id</th>
                      <th>partner-id</th>
                      <th>code</th>
                      <th>username</th>
                      <th>Cluster / Delete URL</th>
                      <th>Durum / İşlem Adımları</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% report.items.forEach((item) => { %>
                      <tr
                        data-obus-user-row-key="<%= item.value %>"
                        data-obus-user-row-source="<%= item.source || '' %>"
                        data-obus-user-row-id="<%= item.id || '' %>"
                        data-obus-user-row-partner-id="<%= item['partner-id'] || '' %>"
                        data-obus-user-row-username="<%= item.username || '' %>"
                        data-obus-user-row-code="<%= item.code || '' %>"
                        data-obus-user-row-delete-url="<%= item.deleteEndpointUrl || '' %>"
                      >
                        <td class="obus-user-deactivate-checkbox-cell">
                          <input type="checkbox" data-obus-user-item="1" name="selectedUsers" value="<%= item.value %>" checked />
                        </td>
                        <td><%= item.id %></td>
                        <td><%= item["partner-id"] %></td>
                        <td><%= item.code %></td>
                        <td><%= item.username %></td>
                        <td class="obus-user-deactivate-target-cell">
                          <span class="obus-user-deactivate-target-cluster"><%= item.source || '-' %></span>
                          <span class="obus-user-deactivate-target-url"><%= item.deleteEndpointUrl || '-' %></span>
                        </td>
                        <td class="obus-live-status pending" data-obus-user-status-cell="1">Bekliyor</td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>

              <div class="obus-user-create-actions">
                <button class="button-link" type="submit">Seçili Kullanıcıları Pasife Al</button>
              </div>

              <div class="obus-user-deactivate-loading-message obus-user-deactivate-delete-loading-message" hidden>
                Seçili kullanıcılar pasife alınıyor...
              </div>
              <div class="inline-alert obus-live-message" data-obus-user-deactivate-live-message="1" hidden></div>
            <% } %>
          </form>

          <% if (report.searchDebugItems && report.searchDebugItems.length > 0) { %>
            <section class="table-card panel-card obus-user-deactivate-debug-section">
              <div class="table-head">
                <h2>Listeleme Debug</h2>
                <div class="table-actions">
                  <span class="pill">Kayıt: <%= report.searchDebugItems.length %></span>
                </div>
              </div>

              <div class="obus-user-deactivate-debug-list">
                <% report.searchDebugItems.forEach((item) => { %>
                  <details
                    class="obus-user-deactivate-debug-item"
                    <% if (item.error || (item.parser && (item.parser.acceptedCount > 0 || (item.parser.samples && item.parser.samples.length > 0)))) { %>open<% } %>
                  >
                    <summary class="obus-user-deactivate-debug-summary">
                      <span><strong><%= item.cluster || '-' %></strong> | <%= item.partnerCode || '-' %> | partner-id: <%= item.partnerId || '-' %></span>
                      <span class="obus-user-deactivate-debug-summary-meta">
                        <% if (item.parser) { %>
                          aday: <%= item.parser.candidateCount || 0 %> | kabul: <%= item.parser.acceptedCount || 0 %> | pasif-elenen: <%= item.parser.skippedInactiveCount || 0 %>
                        <% } else { %>
                          parser yok
                        <% } %>
                        <% if (item.error) { %> | hata: <%= item.error %><% } %>
                      </span>
                    </summary>

                    <div class="obus-user-deactivate-debug-body">
                      <div class="obus-user-deactivate-debug-meta-grid">
                        <div class="obus-user-deactivate-debug-meta-card">
                          <span class="obus-user-deactivate-debug-label">Firma</span>
                          <pre class="obus-user-deactivate-debug-pre"><%= item.companyRef || '-' %></pre>
                        </div>
                        <div class="obus-user-deactivate-debug-meta-card">
                          <span class="obus-user-deactivate-debug-label">Login URL</span>
                          <pre class="obus-user-deactivate-debug-pre"><%= item.loginUrl || '-' %></pre>
                        </div>
                        <div class="obus-user-deactivate-debug-meta-card">
                          <span class="obus-user-deactivate-debug-label">Listeleme URL</span>
                          <pre class="obus-user-deactivate-debug-pre"><%= item.endpointUrl || '-' %></pre>
                        </div>
                      </div>

                      <% if (item.parser) { %>
                        <div class="obus-user-deactivate-debug-meta-grid">
                          <div class="obus-user-deactivate-debug-meta-card">
                            <span class="obus-user-deactivate-debug-label">Parser Özet</span>
                            <pre class="obus-user-deactivate-debug-pre">candidateCount: <%= item.parser.candidateCount || 0 %>
acceptedCount: <%= item.parser.acceptedCount || 0 %>
skippedMissingFieldCount: <%= item.parser.skippedMissingFieldCount || 0 %>
skippedInactiveCount: <%= item.parser.skippedInactiveCount || 0 %>
skippedUnknownStateCount: <%= item.parser.skippedUnknownStateCount || 0 %>
skippedUsernameMismatchCount: <%= item.parser.skippedUsernameMismatchCount || 0 %></pre>
                          </div>
                          <div class="obus-user-deactivate-debug-meta-card">
                            <span class="obus-user-deactivate-debug-label">Parser Samples</span>
                            <pre class="obus-user-deactivate-debug-pre"><%= JSON.stringify(item.parser.samples || [], null, 2) %></pre>
                          </div>
                        </div>
                      <% } %>

                      <% if (item.requestPreview || item.responsePreview || item.responseStatus !== null) { %>
                        <div class="obus-user-deactivate-debug-meta-grid">
                          <div class="obus-user-deactivate-debug-meta-card">
                            <span class="obus-user-deactivate-debug-label">GetUsersWithoutPermissions Preview</span>
                            <pre class="obus-user-deactivate-debug-pre">status: <%= item.responseStatus ?? '-' %>
note: <%= item.responseNote || '-' %>
request: <%= item.requestPreview || '-' %>
response: <%= item.responsePreview || '-' %></pre>
                          </div>
                        </div>
                      <% } %>

                      <% if (item.loginServiceLogs && item.loginServiceLogs.length > 0) { %>
                        <h3 class="obus-user-deactivate-debug-subtitle">1. UserLogin / Session</h3>
                        <div class="obus-user-deactivate-debug-trace-grid">
                          <% item.loginServiceLogs.forEach((trace) => { %>
                            <article class="obus-user-deactivate-debug-trace-card">
                              <strong><%= trace.service || '-' %></strong>
                              <span class="obus-user-deactivate-debug-trace-meta">status: <%= trace.status ?? '-' %></span>
                              <span class="obus-user-deactivate-debug-trace-meta">url: <%= trace.url || '-' %></span>
                              <% if (trace.note) { %><span class="obus-user-deactivate-debug-trace-meta">note: <%= trace.note %></span><% } %>
                              <% if (trace.error) { %><span class="obus-user-deactivate-debug-trace-meta error">error: <%= trace.error %></span><% } %>
                              <span class="obus-user-deactivate-debug-label">Request Body</span>
                              <pre class="obus-user-deactivate-debug-pre"><%= trace.requestBody || '-' %></pre>
                              <span class="obus-user-deactivate-debug-label">Response Body</span>
                              <pre class="obus-user-deactivate-debug-pre"><%= trace.responseBody || '-' %></pre>
                            </article>
                          <% }) %>
                        </div>
                      <% } %>

                      <% if (item.requestTraces && item.requestTraces.length > 0) { %>
                        <h3 class="obus-user-deactivate-debug-subtitle">2. GetUsersWithoutPermissions</h3>
                        <div class="obus-user-deactivate-debug-trace-grid">
                          <% item.requestTraces.forEach((trace) => { %>
                            <article class="obus-user-deactivate-debug-trace-card">
                              <strong><%= trace.service || '-' %></strong>
                              <span class="obus-user-deactivate-debug-trace-meta">status: <%= trace.status ?? '-' %></span>
                              <span class="obus-user-deactivate-debug-trace-meta">url: <%= trace.url || '-' %></span>
                              <% if (trace.note) { %><span class="obus-user-deactivate-debug-trace-meta">note: <%= trace.note %></span><% } %>
                              <% if (trace.error) { %><span class="obus-user-deactivate-debug-trace-meta error">error: <%= trace.error %></span><% } %>
                              <span class="obus-user-deactivate-debug-label">Request Body</span>
                              <pre class="obus-user-deactivate-debug-pre"><%= trace.requestBody || '-' %></pre>
                              <span class="obus-user-deactivate-debug-label">Response Body</span>
                              <pre class="obus-user-deactivate-debug-pre"><%= trace.responseBody || '-' %></pre>
                            </article>
                          <% }) %>
                        </div>
                      <% } %>
                    </div>
                  </details>
                <% }) %>
              </div>
            </section>
          <% } %>

          <% if (report.deleteRequested) { %>
            <section class="table-card panel-card obus-user-create-results">
              <div class="table-head">
                <h2>Pasife Alma Sonuçları</h2>
                <div class="table-actions">
                  <span class="pill">Toplam: <%= report.deleteTotalCount %></span>
                  <span class="pill">Başarılı: <%= report.deleteSuccessCount %></span>
                  <span class="pill">Hatalı: <%= report.deleteFailureCount %></span>
                </div>
              </div>

              <% if (report.deleteSuccessItems && report.deleteSuccessItems.length > 0) { %>
                <h3>Başarılı Kayıtlar</h3>
                <ul class="obus-user-create-result-list success">
                  <% report.deleteSuccessItems.forEach((item) => { %>
                    <li>
                      <strong><%= item.label %></strong>
                      <span><%= item.message %></span>
                    </li>
                  <% }) %>
                </ul>
              <% } %>

              <% if (report.deleteFailureItems && report.deleteFailureItems.length > 0) { %>
                <h3>Hatalı Kayıtlar</h3>
                <ul class="obus-user-create-result-list failure">
                  <% report.deleteFailureItems.forEach((item) => { %>
                    <li>
                      <strong><%= item.label %></strong>
                      <span
                        <% if (item.errorDetail) { %>class="obus-detail-hint" title="<%= item.errorDetail %>"<% } %>
                      ><%= item.error %></span>
                    </li>
                  <% }) %>
                </ul>
              <% } %>
            </section>
          <% } %>
        </section>
      <% } %>
    </section>

    <script src="/public/app.js" defer></script>
  </body>
</html>
