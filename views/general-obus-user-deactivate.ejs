<!DOCTYPE html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bus Product</title>
    <link rel="icon" href="/public/favicon.png" />
    <link rel="stylesheet" href="/public/styles.css" />
  </head>
  <body class="dashboard layout">
    <%- include("partials/sidebar", { active }) %>

    <section class="content">
      <header class="page-header">
        <div class="page-title">
          <h1>
            <span class="page-title-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24">
                <path d="M16 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                <circle cx="10" cy="8" r="4"></circle>
                <path d="M16 11h6"></path>
              </svg>
            </span>
            <span>Obus Kullanıcı Pasife Al</span>
          </h1>
          <p>Tüm firmalar ayrı ayrı sorgulanır; kullanıcı adı birebir eşleşen ve <code>is-active=true</code> olan kayıtlar listelenir.</p>
        </div>
        <div class="page-actions">
          <div class="user-pill"><%= user.displayName %></div>
        </div>
      </header>
      <% if (partnerError) { %>
        <div class="alert inline-alert"><%= partnerError %></div>
      <% } %>

      <section class="table-card panel-card allowed-lines-section">
        <div class="table-head">
          <h2>Sorgu Alanları</h2>
        </div>

        <div class="allowed-lines-grid obus-user-deactivate-grid">
          <label class="allowed-lines-field">
            <span>Kullanıcı Adı</span>
            <input
              type="text"
              name="username"
              value="<%= filters.username || '' %>"
              autocomplete="off"
              placeholder="Kullanıcı adını girin"
            />
          </label>

          <label class="allowed-lines-field allowed-lines-field-company">
            <span>Firmalar</span>
            <select name="company" id="obus-user-deactivate-company">
              <% companyOptions.forEach((company) => { %>
                <option value="<%= company.value %>" <%= filters.company === company.value ? "selected" : "" %>>
                  <%= company.label %>
                </option>
              <% }) %>
            </select>
          </label>
        </div>

        <p class="muted">Firma listesinden seçim yapabilirsiniz; varsayılan seçenek <code>Hepsi</code> olarak gelir.</p>
      </section>
    </section>

    <script src="/public/app.js" defer></script>
  </body>
</html>
