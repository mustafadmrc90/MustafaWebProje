<!DOCTYPE html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <% if (report?.searchJob && report.searchJob.done === false && report.searchJob.refreshUrl) { %>
      <meta http-equiv="refresh" content="3;url=<%= report.searchJob.refreshUrl %>" />
    <% } %>
    <title>Bus Product</title>
    <link rel="icon" href="/public/favicon.png" />
    <link rel="stylesheet" href="/public/styles.css" />
  </head>
  <body class="dashboard layout">
    <%- include("partials/sidebar", { active }) %>

    <section class="content">
      <header class="page-header">
        <div class="page-title">
          <h1>
            <span class="page-title-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24">
                <path d="M7 12h10"></path>
                <circle cx="12" cy="12" r="9"></circle>
              </svg>
            </span>
            <span>Obus Kullanıcı Pasife Al</span>
          </h1>
          <p>Tüm Firmalar listesindeki tüm code kayıtları için username birebir aranır ve sadece `is-active=true` kullanıcılar getirilir.</p>
        </div>
        <div class="page-actions">
          <div class="user-pill"><%= user.displayName %></div>
        </div>
      </header>

      <% if (report && report.error) { %>
        <div class="alert inline-alert"><%= report.error %></div>
      <% } %>

      <section class="table-card panel-card obus-user-deactivate-section">
        <div class="table-head">
          <h2>Kullanıcı Adı</h2>
        </div>

        <form class="obus-user-deactivate-form obus-user-deactivate-search-form" method="get" action="/general/obus-user-deactivate">
          <input type="hidden" name="run" value="1" />

          <div class="obus-user-deactivate-grid">
            <label class="obus-user-create-field">
              <span>Kullanıcı Adı</span>
              <input type="text" name="username" value="<%= filters?.username || '' %>" required />
            </label>
          </div>

          <div class="obus-user-create-actions">
            <button class="button-link" type="submit">Ara</button>
          </div>

          <div class="obus-user-deactivate-loading-message obus-user-deactivate-search-loading-message" hidden>
            Kullanıcı tüm firmalarda aranıyor...
          </div>
        </form>
      </section>

      <% if (report?.searchJob && report.searchJob.done === false) { %>
        <section class="table-card panel-card obus-user-deactivate-section">
          <div class="table-head">
            <h2>Arama Sürüyor</h2>
          </div>
          <p class="muted">Username birebir eşleşmesi ve `is-active=true` filtresi için tüm firmalar taranıyor. Sayfa otomatik yenilenecek.</p>
        </section>
      <% } %>

      <% if (report && report.requested && !(report.searchJob && report.searchJob.done === false)) { %>
        <section class="table-card panel-card obus-user-deactivate-results">
          <form class="obus-user-deactivate-form obus-user-deactivate-delete-form" method="post" action="/general/obus-user-deactivate">
            <input type="hidden" name="username" value="<%= filters?.username || '' %>" />
            <input type="hidden" name="searchJobId" value="<%= report?.searchJob?.id || '' %>" />

            <div class="table-head">
              <h2>Sonuçlar</h2>
              <div class="table-actions">
                <span class="pill">Toplam: <%= report.totalCount %></span>
                <span class="pill">Cluster: <%= report.clusterCount || 0 %></span>
                <% if (report.items && report.items.length > 0) { %>
                  <span class="pill" data-obus-live-progress="1">İşlenen: 0/<%= report.totalCount %></span>
                  <span class="pill success" data-obus-live-success="1">Başarılı: 0</span>
                  <span class="pill muted" data-obus-live-failure="1">Hatalı: 0</span>
                  <label class="obus-user-deactivate-select-all">
                    <input type="checkbox" data-obus-user-select-all="1" checked />
                    <span>Hepsi</span>
                  </label>
                <% } %>
              </div>
            </div>

            <% if ((!report.items || report.items.length === 0) && !report.error) { %>
              <p class="muted">Birebir eşleşen aktif kullanıcı bulunamadı.</p>
            <% } %>

            <% if (report.items && report.items.length > 0) { %>
              <div class="table-scroll obus-user-deactivate-table-scroll">
                <table class="partners-raw-table">
                  <thead>
                    <tr>
                      <th>Seç</th>
                      <th>code</th>
                      <th>cluster</th>
                      <th>partner-id</th>
                      <th>user-id</th>
                      <th>username</th>
                      <th>Durum</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% report.items.forEach((item) => { %>
                      <tr
                        data-obus-user-row-key="<%= item.value %>"
                        data-obus-user-row-source="<%= item.source || '' %>"
                        data-obus-user-row-id="<%= item.id || '' %>"
                        data-obus-user-row-partner-id="<%= item['partner-id'] || '' %>"
                        data-obus-user-row-username="<%= item.username || '' %>"
                        data-obus-user-row-code="<%= item.code || '' %>"
                        data-obus-user-row-delete-url="<%= item.deleteEndpointUrl || '' %>"
                      >
                        <td class="obus-user-deactivate-checkbox-cell">
                          <input type="checkbox" data-obus-user-item="1" name="selectedUsers" value="<%= item.value %>" checked />
                        </td>
                        <td><%= item.code %></td>
                        <td><%= item.source || '-' %></td>
                        <td><%= item["partner-id"] %></td>
                        <td><%= item.id %></td>
                        <td><%= item.username %></td>
                        <td class="obus-live-status pending" data-obus-user-status-cell="1">Bekliyor</td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>

              <div class="obus-user-create-actions">
                <button class="button-link" type="submit">Seçili Kullanıcıları Pasife Al</button>
              </div>

              <div class="obus-user-deactivate-loading-message obus-user-deactivate-delete-loading-message" hidden>
                Seçili kullanıcılar pasife alınıyor...
              </div>
              <div class="inline-alert obus-live-message" data-obus-user-deactivate-live-message="1" hidden></div>
            <% } %>
          </form>

          <% if (report.deleteRequested) { %>
            <section class="table-card panel-card obus-user-create-results">
              <div class="table-head">
                <h2>Pasife Alma Sonuçları</h2>
                <div class="table-actions">
                  <span class="pill">Toplam: <%= report.deleteTotalCount %></span>
                  <span class="pill">Başarılı: <%= report.deleteSuccessCount %></span>
                  <span class="pill">Hatalı: <%= report.deleteFailureCount %></span>
                </div>
              </div>

              <% if (report.deleteSuccessItems && report.deleteSuccessItems.length > 0) { %>
                <h3>Başarılı Kayıtlar</h3>
                <ul class="obus-user-create-result-list success">
                  <% report.deleteSuccessItems.forEach((item) => { %>
                    <li>
                      <strong><%= item.label %></strong>
                      <span><%= item.message %></span>
                    </li>
                  <% }) %>
                </ul>
              <% } %>

              <% if (report.deleteFailureItems && report.deleteFailureItems.length > 0) { %>
                <h3>Hatalı Kayıtlar</h3>
                <ul class="obus-user-create-result-list failure">
                  <% report.deleteFailureItems.forEach((item) => { %>
                    <li>
                      <strong><%= item.label %></strong>
                      <span
                        <% if (item.errorDetail) { %>class="obus-detail-hint" title="<%= item.errorDetail %>"<% } %>
                      ><%= item.error %></span>
                    </li>
                  <% }) %>
                </ul>
              <% } %>
            </section>
          <% } %>
        </section>
      <% } %>
    </section>

    <script src="/public/app.js" defer></script>
  </body>
</html>
