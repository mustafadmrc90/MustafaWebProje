<!DOCTYPE html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bus Product</title>
    <link rel="icon" href="/public/favicon.png" />
    <link rel="stylesheet" href="/public/styles.css" />
  </head>
  <body class="dashboard layout">
    <%- include("partials/sidebar", { active }) %>

    <section class="content">
      <header class="page-header">
        <div class="page-title">
          <h1>
            <span class="page-title-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24">
                <path d="M16 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                <circle cx="10" cy="8" r="4"></circle>
                <path d="M16 11h6"></path>
              </svg>
            </span>
            <span>Obus Kullanıcı Pasife Al</span>
          </h1>
          <p>Seçilen firmalar için kullanıcılar listelenir. İsterseniz <code>Hepsi</code> ile tüm firmaları aynı anda taratabilirsiniz.</p>
        </div>
        <div class="page-actions">
          <div class="user-pill"><%= user.displayName %></div>
        </div>
      </header>
      <%- include("partials/page-screen-log", { screenLogPanel }) %>

      <% if (partnerError) { %>
        <div class="alert inline-alert"><%= partnerError %></div>
      <% } %>

      <div
        class="obus-user-deactivate-layout"
        data-obus-user-deactivate-page="1"
        data-obus-user-deactivate-initial-job-id="<%= liveJob?.id || '' %>"
        data-obus-user-deactivate-initial-created-at="<%= liveJob?.createdAt || 0 %>"
        data-obus-user-deactivate-initial-finished-at="<%= liveJob?.finishedAt || 0 %>"
        data-obus-user-deactivate-initial-total-count="<%= liveJob?.totalCount || 0 %>"
        data-obus-user-deactivate-initial-processed-count="<%= liveJob?.processedCount || 0 %>"
        data-obus-user-deactivate-initial-success-count="<%= liveJob?.successCount || 0 %>"
        data-obus-user-deactivate-initial-failure-count="<%= liveJob?.failureCount || 0 %>"
        data-obus-user-deactivate-initial-done="<%= liveJob?.done ? '1' : '0' %>"
      >
        <section class="table-card panel-card allowed-lines-response">
          <div class="table-head">
            <h2>Sonuçlar</h2>
            <div class="table-actions">
              <span class="pill" data-obus-user-deactivate-http="1">HTTP -</span>
              <span class="pill" data-obus-user-deactivate-duration="1">Süre -</span>
              <span class="pill" data-obus-user-deactivate-scanned="1">0 Firma</span>
              <span class="pill" data-obus-user-deactivate-success="1">0 Başarılı</span>
              <span class="pill" data-obus-user-deactivate-failure="1">0 Hatalı</span>
              <span class="pill" data-obus-user-deactivate-total-users="1">0 Kullanıcı</span>
              <span class="pill" data-obus-user-deactivate-active-users="1">0 Aktif</span>
              <span class="pill" data-obus-user-deactivate-matched="1">0 Listelendi</span>
            </div>
          </div>

          <div class="table-scroll">
            <table class="partners-raw-table">
              <thead>
                <tr>
                  <th>id</th>
                  <th>username</th>
                  <th>full-name</th>
                  <th>is-active</th>
                  <th>code</th>
                  <th>cluster-url</th>
                </tr>
              </thead>
              <tbody data-obus-user-deactivate-table-body="1"></tbody>
            </table>
          </div>

          <div class="pill muted" data-obus-user-deactivate-empty="1">Listelenen kullanıcılar burada gösterilecek.</div>
        </section>

        <aside class="table-card panel-card obus-user-deactivate-controls">
          <div class="table-head">
            <h2>Firma Seçimi</h2>
          </div>

          <div class="obus-user-deactivate-controls-body">
            <label class="allowed-lines-field">
              <span>Firmalar</span>
              <input type="hidden" value="[]" data-obus-user-deactivate-selected-companies="1" />
              <div class="obus-company-multiselect">
                <button
                  type="button"
                  class="obus-company-trigger"
                  data-obus-user-deactivate-company-trigger="1"
                  aria-haspopup="listbox"
                  aria-expanded="false"
                >
                  Firma seçiniz
                </button>

                <div class="obus-company-dropdown" data-obus-user-deactivate-company-dropdown="1" role="listbox" hidden>
                  <label class="obus-company-option obus-company-option-all">
                    <input type="checkbox" data-obus-user-deactivate-select-all="1" />
                    <span>Hepsi</span>
                  </label>

                  <% companyOptions.forEach((company) => { %>
                    <label class="obus-company-option" data-obus-user-deactivate-company-option-row="1">
                      <input
                        type="checkbox"
                        data-obus-user-deactivate-company-checkbox="1"
                        value="<%= company.value %>"
                        data-company-label="<%= company.label %>"
                        data-company-code="<%= company.code %>"
                        data-company-id="<%= company.id %>"
                        data-company-cluster="<%= company.cluster %>"
                        data-company-branch-id="<%= company.branchId %>"
                        data-company-url="<%= company.url %>"
                      />
                      <span><%= company.label %></span>
                    </label>
                  <% }) %>
                </div>
              </div>
              <small class="muted">Liste Tüm Firmalar ekranındaki SQL verisinden gelir. Çoklu seçim yapılabilir.</small>
            </label>

            <div class="allowed-lines-actions">
              <button
                type="button"
                data-obus-user-deactivate-submit="1"
                data-default-label="Kullanıcıları Listele"
                data-loading-label="Listeleniyor..."
              >
                Kullanıcıları Listele
              </button>
            </div>

            <div class="allowed-lines-loading-message" data-obus-user-deactivate-loading="1" hidden>Kullanıcılar listeleniyor...</div>

            <div class="obus-user-create-status muted" data-obus-user-deactivate-status="1">
              Sağdaki firma listesinden seçim yapın ve listelemeyi başlatın.
            </div>

            <div class="obus-user-create-live-summary" data-obus-user-deactivate-summary="1">
              Sonuç özeti burada canlı olarak güncellenecek.
            </div>
          </div>
        </aside>
      </div>
    </section>

    <script src="/public/app.js" defer></script>
  </body>
</html>
