<!DOCTYPE html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bus Product</title>
    <link rel="icon" href="/public/favicon.png" />
    <link rel="stylesheet" href="/public/styles.css" />
  </head>
  <body class="dashboard layout">
    <%- include("partials/sidebar", { active }) %>

    <section class="content">
      <header class="page-header">
        <div class="page-title">
          <h1>
            <span class="page-title-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24">
                <path d="M12 5v14"></path>
                <path d="M5 12h14"></path>
                <circle cx="12" cy="12" r="9"></circle>
              </svg>
            </span>
            <span>Obus Kullanıcı Oluştur</span>
          </h1>
          <p>Firma seçimi ve body alanları buradan hazırlanır.</p>
        </div>
        <div class="page-actions">
          <div class="user-pill"><%= user.displayName %></div>
        </div>
      </header>

      <% if (bulkMode) { %>
        <div class="inline-success">Toplu kullanıcı oluşturma modu seçildi.</div>
      <% } %>
      <% if (partnerError) { %>
        <div class="alert inline-alert"><%= partnerError %></div>
      <% } %>

      <section class="table-card panel-card obus-user-create-section">
        <div class="table-head">
          <h2>Kullanıcı Oluşturma Hazırlığı</h2>
          <div class="table-actions">
            <form method="get" action="/general/obus-user-create">
              <input type="hidden" name="bulk" value="1" />
              <button class="button-link" type="submit">Kullanıcıları Tüm Firmalar Oluştur</button>
            </form>
          </div>
        </div>

        <form class="obus-user-create-form" method="get" action="/general/obus-user-create">
          <input type="hidden" name="bulk" value="<%= bulkMode ? '1' : '0' %>" />
          <input
            type="hidden"
            name="selectedCompanies"
            id="obus-user-create-selected-companies"
            value="<%= selectedCompaniesJson || '[]' %>"
          />
          <input type="hidden" id="obus-user-create-edit-values" value="{}" />

          <div class="obus-user-create-grid">
            <label class="obus-user-create-field obus-user-create-field-company">
              <span>Firmalar</span>
              <div class="obus-company-multiselect">
                <button
                  type="button"
                  class="obus-company-trigger"
                  id="obus-company-trigger"
                  aria-haspopup="listbox"
                  aria-expanded="false"
                >
                  Hepsi
                </button>
                <div class="obus-company-dropdown" id="obus-company-dropdown" role="listbox" hidden>
                  <label class="obus-company-option obus-company-option-all">
                    <input type="checkbox" data-select-all="1" />
                    <span>Hepsi</span>
                  </label>

                  <% companies.forEach((company) => { %>
                    <label class="obus-company-option">
                      <input
                        type="checkbox"
                        data-company-checkbox="1"
                        value="<%= company.value %>"
                        <%= selectedCompanyValues.includes(company.value) ? "checked" : "" %>
                      />
                      <span><%= company.label %></span>
                    </label>
                  <% }) %>
                </div>
              </div>
              <small class="muted">Varsayılan olarak Hepsi seçili gelir. Sadece işaretli firmalara istek atılacak.</small>
            </label>

            <label class="obus-user-create-field obus-user-create-field-template">
              <span>Body Template</span>
              <textarea id="obus-user-create-body-template" name="bodyTemplate" rows="12"><%= bodyTemplate %></textarea>
              <small class="muted">`{{edit:alan_adi}}` veya `{{edit}}` taglerini kullanabilirsin.</small>
            </label>
          </div>

          <div class="obus-user-create-actions">
            <button class="button-link ghost" type="submit">Seçimi Koruyarak Yenile</button>
          </div>

          <div class="obus-user-create-loading-message" hidden>Hazırlanıyor...</div>
        </form>
      </section>

      <section class="table-card panel-card obus-user-create-editor-section">
        <div class="table-head">
          <h2>Body Alanları</h2>
        </div>
        <div id="obus-user-create-edit-fields" class="obus-edit-fields"></div>
        <label class="obus-user-create-field obus-user-create-preview">
          <span>Doldurulmuş Body Önizleme</span>
          <textarea id="obus-user-create-body-preview" rows="12" readonly></textarea>
        </label>
      </section>
    </section>

    <script src="/public/app.js" defer></script>
  </body>
</html>
