<!DOCTYPE html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bus Product</title>
    <link rel="icon" href="/public/favicon.png" />
    <link rel="stylesheet" href="/public/styles.css" />
  </head>
  <body class="dashboard layout obus-user-create-page <%= bulkMode ? 'obus-user-create-bulk-page' : '' %>">
    <%- include("partials/sidebar", { active }) %>

    <section class="content">
      <header class="page-header">
        <div class="page-title">
          <h1>
            <span class="page-title-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24">
                <path d="M12 5v14"></path>
                <path d="M5 12h14"></path>
                <circle cx="12" cy="12" r="9"></circle>
              </svg>
            </span>
            <span><%= bulkMode ? 'Toplu Obus Kullanıcıları Oluştur' : 'Obus Kullanıcı Oluştur' %></span>
          </h1>
          <p><%= bulkMode ? 'Firma seçimi ve çoklu kullanıcı satırları buradan hazırlanır.' : 'Firma seçimi ve kullanıcı alanları buradan hazırlanır.' %></p>
        </div>
        <div class="page-actions">
          <div class="user-pill"><%= user.displayName %></div>
        </div>
      </header>

      <% if (bulkMode) { %>
        <div class="inline-success">Toplu kullanıcı oluşturma modu seçildi.</div>
      <% } %>
      <% if (partnerError) { %>
        <div class="alert inline-alert"><%= partnerError %></div>
      <% } %>
      <% if (report && report.error) { %>
        <div class="alert inline-alert"><%= report.error %></div>
      <% } %>

      <section class="table-card panel-card obus-user-create-section">
        <div class="table-head">
          <h2><%= bulkMode ? 'Toplu Kullanıcı Oluşturma Hazırlığı' : 'Kullanıcı Oluşturma Hazırlığı' %></h2>
        </div>

        <form
          class="obus-user-create-form"
          method="post"
          action="<%= formAction || '/general/obus-user-create' %>"
          data-obus-live-start-url="<%= liveStartApiPath || '/api/obus-user-create/live/start' %>"
          data-obus-bulk-check-url="<%= bulkCheckApiPath || '/api/obus-user-create-bulk/check' %>"
        >
          <input type="hidden" name="bulk" value="<%= bulkMode ? '1' : '0' %>" />
          <input
            type="hidden"
            name="selectedCompanies"
            id="obus-user-create-selected-companies"
            value="<%= selectedCompaniesJson || '[]' %>"
          />

          <div class="obus-user-create-grid">
            <label class="obus-user-create-field obus-user-create-field-company">
              <span>Firmalar</span>
              <div class="obus-company-multiselect">
                <button
                  type="button"
                  class="obus-company-trigger"
                  id="obus-company-trigger"
                  aria-haspopup="listbox"
                  aria-expanded="false"
                >
                  Hepsi
                </button>
                <div class="obus-company-dropdown" id="obus-company-dropdown" role="listbox" hidden>
                  <label class="obus-company-option obus-company-option-all">
                    <input type="checkbox" data-select-all="1" />
                    <span>Hepsi</span>
                  </label>

                  <% companies.forEach((company) => { %>
                    <label class="obus-company-option" data-company-option-row="1">
                      <input
                        type="checkbox"
                        data-company-checkbox="1"
                        value="<%= company.value %>"
                        <%= selectedCompanyValues.includes(company.value) ? "checked" : "" %>
                      />
                      <span><%= company.label %></span>
                    </label>
                  <% }) %>
                </div>
              </div>
              <small class="muted">Varsayılan olarak Hepsi seçili gelir. Sadece işaretli firmalara istek atılacak.</small>
            </label>

            <% if (bulkMode) { %>
              <div class="obus-user-create-field obus-user-create-field-bulk-users">
                <span>Kullanıcı Satırları</span>
                <div class="obus-bulk-user-list" data-obus-bulk-user-list="1">
                  <div class="obus-bulk-user-row" data-obus-bulk-user-row="1" data-obus-bulk-entry-id="row-1">
                    <input
                      type="text"
                      placeholder="Ad Soyad"
                      data-obus-bulk-user-full-name="1"
                      autocomplete="off"
                    />
                    <input
                      type="text"
                      placeholder="KullanıcıAdı"
                      data-obus-bulk-user-username="1"
                      autocomplete="off"
                    />
                    <input
                      type="password"
                      placeholder="Şifre"
                      data-obus-bulk-user-password="1"
                      autocomplete="new-password"
                    />
                    <button type="button" class="ghost" data-obus-bulk-remove-row="1">Sil</button>
                  </div>
                </div>
                <small class="muted">Sorgu sadece KullanıcıAdı ile yapılır; oluşturma için Ad Soyad ve Şifre alanlarını da doldurun.</small>
              </div>
            <% } else { %>
              <label class="obus-user-create-field">
                <span>Ad Soyad</span>
                <input type="text" name="fullName" value="<%= formValues?.fullName || '' %>" />
              </label>

              <label class="obus-user-create-field">
                <span>KullanıcıAdı</span>
                <input type="text" name="username" value="<%= formValues?.username || '' %>" />
              </label>

              <label class="obus-user-create-field">
                <span>Şifre</span>
                <input type="password" name="password" value="<%= formValues?.password || '' %>" />
              </label>
            <% } %>
          </div>

          <div class="obus-user-create-actions">
            <% if (bulkMode) { %>
              <button class="button-link ghost" type="button" data-obus-bulk-add-row="1">+ Satır Ekle</button>
              <button class="button-link" type="submit" data-obus-bulk-check-button="1">Kullanıcıları Sorgula</button>
              <button class="button-link" type="button" data-obus-bulk-create-button="1" disabled>Yok Olanları Oluştur</button>
            <% } else { %>
              <button class="button-link" type="submit">Kullanıcı Oluştur</button>
            <% } %>
          </div>

          <div class="obus-user-create-loading-message" hidden>Kullanıcı oluşturma isteği hazırlanıyor...</div>
          <div class="inline-alert obus-live-message" data-obus-user-create-live-message="1" hidden></div>
        </form>
      </section>

      <% if (bulkMode) { %>
        <section class="table-card panel-card obus-user-create-bulk-check-results" data-obus-bulk-check-results="1" hidden>
          <div class="table-head">
            <h2>Firma Bazlı Kullanıcı Sorgu Sonucu</h2>
            <div class="table-actions">
              <span class="pill" data-obus-bulk-check-total="1">Toplam: 0</span>
              <span class="pill success" data-obus-bulk-check-missing="1">Yok: 0</span>
              <span class="pill muted" data-obus-bulk-check-existing="1">Var: 0</span>
              <span class="pill muted" data-obus-bulk-check-error="1">Hata: 0</span>
            </div>
          </div>
          <div class="table-head">
            <div class="table-actions">
              <label class="obus-user-create-field obus-bulk-filter-field">
                <span>Filtre</span>
                <select data-obus-bulk-filter="1">
                  <option value="all">Hepsi</option>
                  <option value="missing">Sadece Yok</option>
                  <option value="existing">Sadece Var</option>
                </select>
              </label>
              <label class="obus-user-deactivate-select-all">
                <input type="checkbox" data-obus-bulk-select-all="1" checked />
                <span>Yok olanların tümünü seç</span>
              </label>
            </div>
          </div>
          <div class="table-scroll">
            <table class="partners-raw-table obus-user-create-bulk-check-table">
              <thead>
                <tr>
                  <th>Seç</th>
                  <th>Firma</th>
                  <th>KullanıcıAdı</th>
                  <th>Ad Soyad</th>
                  <th>Durum</th>
                </tr>
              </thead>
              <tbody data-obus-bulk-check-body="1"></tbody>
            </table>
          </div>
        </section>
      <% } %>

      <section class="table-card panel-card obus-user-create-live-results" data-obus-user-create-live-results="1" hidden>
        <div class="table-head">
          <h2>Canlı İşlem Durumu</h2>
          <div class="table-actions">
            <span class="pill" data-obus-create-live-progress="1">İşlenen: 0/0</span>
            <span class="pill success" data-obus-create-live-success="1">Başarılı: 0</span>
            <span class="pill muted" data-obus-create-live-failure="1">Hatalı: 0</span>
          </div>
        </div>
        <div class="table-scroll">
          <table class="partners-raw-table obus-user-create-live-table">
            <thead>
              <tr>
                <th>Firma</th>
                <th>Durum</th>
              </tr>
            </thead>
            <tbody data-obus-user-create-live-body="1"></tbody>
          </table>
        </div>
      </section>

      <% if (report && report.requested) { %>
        <section class="table-card panel-card obus-user-create-results">
          <div class="table-head">
            <h2>İşlem Sonuçları</h2>
            <div class="table-actions">
              <span class="pill">Toplam: <%= report.totalCount %></span>
              <span class="pill">Başarılı: <%= report.successCount %></span>
              <span class="pill">Hatalı: <%= report.failureCount %></span>
            </div>
          </div>

          <% if (report.successItems && report.successItems.length > 0) { %>
            <h3>Başarılı Firmalar</h3>
            <ul class="obus-user-create-result-list success">
              <% report.successItems.forEach((item) => { %>
                <li>
                  <strong><%= item.label %></strong>
                  <span><%= item.message %></span>
                </li>
              <% }) %>
            </ul>
          <% } %>

          <% if (report.failureItems && report.failureItems.length > 0) { %>
            <h3>Hatalı Firmalar</h3>
            <ul class="obus-user-create-result-list failure">
              <% report.failureItems.forEach((item) => { %>
                <li>
                  <strong><%= item.label %></strong>
                  <span
                    <% if (item.errorDetail) { %>class="obus-detail-hint" title="<%= item.errorDetail %>"<% } %>
                  ><%= item.error %></span>
                </li>
              <% }) %>
            </ul>
          <% } %>
        </section>
      <% } %>
    </section>

    <script src="/public/app.js" defer></script>
  </body>
</html>
